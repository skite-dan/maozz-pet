{
  "name": "maozz-pet",
  "version": "2.0.0",
  "description": "毛茸茸星球 - 00后养宠社区（前后端分离架构）",
  "main": "front/server.js",
  "scripts": {
    "start:front": "node front/server.js",
    "start:admin": "node admin/server.js",
    "start": "npm-run-all --parallel start:front start:admin",
    "dev:front": "nodemon front/server.js",
    "dev:admin": "nodemon admin/server.js",
    "dev": "npm-run-all --parallel dev:front dev:admin",
    "init-db": "mysql -u pet -p\"pet147258!\" pet < sql/init.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^2.1.35",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "redis": "^4.7.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "npm-run-all": "^4.1.5"
  }
}
