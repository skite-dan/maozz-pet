<%
  var body = '';
  body += '<div class="breadcrumb">';
  body += '  <a href="/">首页</a> <span class="sep">/</span>';
  body += '  <span class="current">联系我们</span>';
  body += '</div>';

  body += '<div class="page-layout">';
  body += '  <div class="content-area">';

  body += '    <div class="card" style="padding:32px;">';
  body += '      <h2 class="section-title"><span class="icon">📧</span> 联系我们</h2>';
  body += '      <p style="color:var(--muted);margin-bottom:24px;">如果你有任何问题、建议或合作意向，请填写以下表单，我们会尽快回复。</p>';

  body += '      <div class="form-group">';
  body += '        <label class="form-label">你的昵称 <span style="color:var(--accent);">*</span></label>';
  body += '        <input type="text" class="form-input" id="contactName" placeholder="请输入昵称">';
  body += '      </div>';
  body += '      <div class="form-group">';
  body += '        <label class="form-label">邮箱 <span style="color:var(--accent);">*</span></label>';
  body += '        <input type="email" class="form-input" id="contactEmail" placeholder="请输入邮箱">';
  body += '      </div>';
  body += '      <div class="form-group">';
  body += '        <label class="form-label">主题</label>';
  body += '        <select class="form-input" id="contactSubject">';
  body += '          <option value="">请选择主题</option>';
  body += '          <option value="feedback">意见反馈</option>';
  body += '          <option value="cooperation">商务合作</option>';
  body += '          <option value="bug">问题反馈</option>';
  body += '          <option value="other">其他</option>';
  body += '        </select>';
  body += '      </div>';
  body += '      <div class="form-group">';
  body += '        <label class="form-label">留言内容 <span style="color:var(--accent);">*</span></label>';
  body += '        <textarea class="form-input" id="contactMessage" placeholder="请详细描述你的问题或建议..." rows="6"></textarea>';
  body += '      </div>';
  body += '      <button class="btn btn-primary" onclick="submitContact()">发送留言</button>';
  body += '    </div>';

  body += '  </div>';

  // Sidebar
  body += '  <aside class="sidebar">';
  body += '    <div class="widget">';
  body += '      <h3 class="widget-title">📍 联系方式</h3>';
  body += '      <div style="font-size:0.9rem;color:var(--ink);line-height:2.2;">';
  body += '        <p>📧 邮箱：contact@maozz.com</p>';
  body += '        <p>💬 微信：MaozzPet</p>';
  body += '        <p>📱 微博：@毛茸茸星球</p>';
  body += '        <p>🕐 工作时间：周一至周五 9:00-18:00</p>';
  body += '      </div>';
  body += '    </div>';

  body += '    <div class="widget">';
  body += '      <h3 class="widget-title">❓ 常见问题</h3>';
  body += '      <div style="font-size:0.88rem;color:var(--muted);line-height:1.8;">';
  body += '        <p><strong style="color:var(--ink);">如何注册？</strong><br>点击页面右上角的"注册"按钮即可。</p>';
  body += '        <p><strong style="color:var(--ink);">如何发帖？</strong><br>登录后点击右下角的发帖按钮。</p>';
  body += '        <p><strong style="color:var(--ink);">忘记密码怎么办？</strong><br>请联系管理员重置密码。</p>';
  body += '      </div>';
  body += '    </div>';
  body += '  </aside>';
  body += '</div>';
%>

<%
  var pageScript = '';
  pageScript += '<script>';
  pageScript += 'async function submitContact() {';
  pageScript += '  const name = document.getElementById("contactName").value.trim();';
  pageScript += '  const email = document.getElementById("contactEmail").value.trim();';
  pageScript += '  const message = document.getElementById("contactMessage").value.trim();';
  pageScript += '  if (!name || !email || !message) { showToast("请填写必填项", "error"); return; }';
  pageScript += '  try {';
  pageScript += '    const res = await authFetch("/api/messages", {';
  pageScript += '      method: "POST",';
  pageScript += '      headers: { "Content-Type": "application/json" },';
  pageScript += '      body: JSON.stringify({ content: "[联系表单] " + name + " (" + email + "): " + message, nickname: name })';
  pageScript += '    });';
  pageScript += '    const data = await res.json();';
  pageScript += '    if (data.code === 201 || data.code === 200) {';
  pageScript += '      showToast("留言发送成功，我们会尽快回复！", "success");';
  pageScript += '      document.getElementById("contactName").value = "";';
  pageScript += '      document.getElementById("contactEmail").value = "";';
  pageScript += '      document.getElementById("contactMessage").value = "";';
  pageScript += '    } else {';
  pageScript += '      showToast(data.message || "发送失败", "error");';
  pageScript += '    }';
  pageScript += '  } catch(e) { showToast("网络错误", "error"); }';
  pageScript += '}';
  pageScript += '</script>';
%>

<%- include('layout', { title: title, bodyClass: 'page-contact', body: body, pageScript: pageScript }) %>
