<%# comments.ejs - 评论管理 %>
<%
var body = '';

body += '<div class="page-header">';
body += '  <h1>评论管理</h1>';
body += '  <p>管理平台所有评论内容，审核与维护</p>';
body += '</div>';

body += '<!-- 筛选栏 -->';
body += '<div class="filter-bar">';
body += '  <select id="filterStatus" onchange="handleFilter()">';
body += '    <option value="">全部状态</option>';
body += '    <option value="normal">正常</option>';
body += '    <option value="pending">待审核</option>';
body += '    <option value="hidden">已隐藏</option>';
body += '    <option value="deleted">已删除</option>';
body += '  </select>';
body += '  <div class="search-input">';
body += '    <input type="text" id="searchKeyword" placeholder="搜索评论内容..." onkeydown="if(event.key===\'Enter\')handleFilter()">';
body += '  </div>';
body += '  <select id="pageSize" onchange="handlePageSizeChange()">';
body += '    <option value="10">10条/页</option>';
body += '    <option value="30">30条/页</option>';
body += '    <option value="50">50条/页</option>';
body += '  </select>';
body += '  <button class="btn btn-primary" onclick="handleFilter()">&#x1F50D; 搜索</button>';
body += '  <button class="btn btn-outline" onclick="resetFilter()">&#x21BA; 重置</button>';
body += '</div>';

body += '<!-- 评论表格 -->';
body += '<div class="card">';
body += '  <div class="card-header">';
body += '    <h2>评论列表</h2>';
body += '    <span id="commentCount" style="font-size:13px;color:#94a3b8;"></span>';
body += '  </div>';
body += '  <div class="table-wrapper">';
body += '    <table class="data-table" id="commentsTable">';
body += '      <thead>';
body += '        <tr>';
body += '          <th data-sort="id">ID <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th>内容摘要</th>';
body += '          <th>评论者</th>';
body += '          <th>所属帖子</th>';
body += '          <th data-sort="status">状态 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="created_at">创建时间 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th>操作</th>';
body += '        </tr>';
body += '      </thead>';
body += '      <tbody id="commentsBody">';
body += '        <tr><td colspan="7"><div class="loading-spinner"></div></td></tr>';
body += '      </tbody>';
body += '    </table>';
body += '  </div>';
body += '  <div id="paginationContainer"></div>';
body += '</div>';

var pageScript = '';
pageScript += '<script>';
pageScript += '  let currentPage = 1;';
pageScript += '  let pageSize = 10;';
pageScript += '  let currentSort = "";';
pageScript += '  let currentDir = "";';
pageScript += '  var initialComments = ' + JSON.stringify((initialData && initialData.comments) ? initialData.comments : []) + ';';
pageScript += '  var initialTotal = ' + ((initialData && initialData.total) ? initialData.total : 0) + ';';
pageScript += '';
pageScript += '  /* ========== Load Comments ========== */';
pageScript += '  async function loadComments() {';
pageScript += '    const status = document.getElementById("filterStatus").value;';
pageScript += '    const keyword = document.getElementById("searchKeyword").value.trim();';
pageScript += '    pageSize = parseInt(document.getElementById("pageSize").value) || 10;';
pageScript += '';
pageScript += '    let url = "/api/admin/comments?page=" + currentPage + "&limit=" + pageSize;';
pageScript += '    if (status !== "") url += "&status=" + status;';
pageScript += '    if (keyword) url += "&keyword=" + encodeURIComponent(keyword);';
pageScript += '    if (currentSort) url += "&sortBy=" + currentSort + "&sortDir=" + currentDir;';
pageScript += '';
pageScript += '    const res = await adminFetch(url);';
pageScript += '    if (!res || !res.ok) {';
pageScript += '      var tbody = document.getElementById("commentsBody");';
pageScript += '      tbody.innerHTML = "<tr><td colspan=\\"7\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div></td></tr>";';
pageScript += '      document.getElementById("commentCount").textContent = "";';
pageScript += '      return;';
pageScript += '    }';
pageScript += '    const data = await res.json();';
pageScript += '';
pageScript += '    if (data.code === 200 && data.data) {';
pageScript += '      var list = data.data.list || data.data.comments || [];';
pageScript += '      if (list.length === 0) {';
pageScript += '        document.getElementById("commentsBody").innerHTML = "<tr><td colspan=\\"7\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x1F4ED;</div><p>暂无评论数据</p></div></td></tr>";';
pageScript += '        document.getElementById("commentCount").textContent = "共 0 条记录";';
pageScript += '        document.getElementById("paginationContainer").innerHTML = "";';
pageScript += '      } else {';
pageScript += '        renderComments(list);';
pageScript += '        const total = data.data.total || 0;';
pageScript += '        const totalPages = Math.ceil(total / pageSize);';
pageScript += '        document.getElementById("commentCount").textContent = "共 " + total + " 条记录";';
pageScript += '        renderPagination("paginationContainer", currentPage, totalPages, function(page) {';
pageScript += '          currentPage = page;';
pageScript += '          loadComments();';
pageScript += '        });';
pageScript += '      }';
pageScript += '    } else {';
pageScript += '      var tbody2 = document.getElementById("commentsBody");';
pageScript += '      tbody2.innerHTML = "<tr><td colspan=\\"7\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div></td></tr>";';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Render Comments ========== */';
pageScript += '  function renderComments(comments) {';
pageScript += '    const tbody = document.getElementById("commentsBody");';
pageScript += '    if (!comments || comments.length === 0) {';
pageScript += '      tbody.innerHTML = \'<tr><td colspan="7"><div class="empty-state"><div class="empty-icon">&#x1F4ED;</div><p>暂无评论数据</p></div></td></tr>\';';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    const statusMap = { "normal": { text: "正常", cls: "success" }, "pending": { text: "待审核", cls: "warning" }, "hidden": { text: "已隐藏", cls: "default" }, "deleted": { text: "已删除", cls: "danger" }, "default": { text: "未知", cls: "default" } };';
pageScript += '';
pageScript += '    tbody.innerHTML = comments.map(c => \'<tr>\' +';
pageScript += '      \'<td class="cell-id">\' + (c.id || \'-\') + \'</td>\' +';
pageScript += '      \'<td class="cell-content" title="\' + escapeHtml(c.content || \'\') + \'">\' + escapeHtml(truncate(c.content || \'-\', 40)) + \'</td>\' +';
pageScript += '      \'<td>\' + escapeHtml(c.username || c.authorName || \'-\') + \'</td>\' +';
pageScript += '      \'<td class="cell-content" title="\' + escapeHtml(c.postTitle || c.post_title || \'\') + \'">\' +';
pageScript += '        (c.post_id || c.postId';
pageScript += '          ? \'<a href="/posts/\' + (c.post_id || c.postId) + \'" target="_blank" style="color:#3b82f6;">\' + escapeHtml(truncate(c.postTitle || c.post_title || ("帖子#" + (c.post_id || c.postId)), 20)) + \'</a>\'';
pageScript += '          : \'-\'';
pageScript += '        ) +';
pageScript += '      \'</td>\' +';
pageScript += '      \'<td>\' + statusTag(c.status, statusMap) + \'</td>\' +';
pageScript += '      \'<td style="font-size:12px;color:#64748b;white-space:nowrap;">\' + formatDate(c.created_at || c.createdAt) + \'</td>\' +';
pageScript += '      \'<td>\' +';
pageScript += '        \'<div style="display:flex;gap:4px;flex-wrap:nowrap;">\' +';
pageScript += '        \'<button class="btn btn-sm \' + (c.status === 2 ? \'btn-success\' : \'btn-warning\') + \'"\' +';
pageScript += '        \' onclick="toggleCommentVisibility(\' + c.id + \', \' + c.status + \')">\' +';
pageScript += '        (c.status === 2 ? \'&#x1F441; 显示\' : \'&#x1F6AE; 隐藏\') +';
pageScript += '        \'</button>\' +';
pageScript += '        \'<button class="btn btn-sm btn-danger" onclick="deleteComment(\' + c.id + \')">&#x1F5D1;</button>\' +';
pageScript += '        \'</div>\' +';
pageScript += '      \'</td>\' +';
pageScript += '      \'</tr>\').join(\'\');';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Toggle Comment Visibility ========== */';
pageScript += '  async function toggleCommentVisibility(commentId, currentStatus) {';
pageScript += '    const newStatus = currentStatus === 2 ? 1 : 2;';
pageScript += '    const action = newStatus === 2 ? "隐藏" : "显示";';
pageScript += '';
pageScript += '    showConfirm(';
pageScript += '      action + "评论",';
pageScript += '      "确定要" + action + "该评论吗？",';
pageScript += '      async function() {';
pageScript += '        const res = await adminFetch("/api/admin/comments/" + commentId + "/status", {';
pageScript += '          method: "PUT",';
pageScript += '          body: JSON.stringify({ status: newStatus })';
pageScript += '        });';
pageScript += '        if (!res) return;';
pageScript += '        const data = await res.json();';
pageScript += '        if (data.code === 200) {';
pageScript += '          showToast("评论已" + action, "success");';
pageScript += '          loadComments();';
pageScript += '        } else {';
pageScript += '          showToast(data.message || "操作失败", "error");';
pageScript += '        }';
pageScript += '      }';
pageScript += '    );';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Delete Comment ========== */';
pageScript += '  async function deleteComment(commentId) {';
pageScript += '    showConfirm(';
pageScript += '      "删除评论",';
pageScript += '      "确定要删除该评论吗？此操作不可恢复。",';
pageScript += '      async function() {';
pageScript += '        const res = await adminFetch("/api/admin/comments/" + commentId, {';
pageScript += '          method: "DELETE"';
pageScript += '        });';
pageScript += '        if (!res) return;';
pageScript += '        const data = await res.json();';
pageScript += '        if (data.code === 200) {';
pageScript += '          showToast("评论已删除", "success");';
pageScript += '          loadComments();';
pageScript += '        } else {';
pageScript += '          showToast(data.message || "删除失败", "error");';
pageScript += '        }';
pageScript += '      }';
pageScript += '    );';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Filter ========== */';
pageScript += '  function handleFilter() {';
pageScript += '    currentPage = 1;';
pageScript += '    loadComments();';
pageScript += '  }';
pageScript += '';
pageScript += '  function resetFilter() {';
pageScript += '    document.getElementById("filterStatus").value = "";';
pageScript += '    document.getElementById("searchKeyword").value = "";';
pageScript += '    document.getElementById("pageSize").value = "10";';
pageScript += '    currentPage = 1;';
pageScript += '    pageSize = 10;';
pageScript += '    currentSort = "";';
pageScript += '    currentDir = "";';
pageScript += '    loadComments();';
pageScript += '  }';
pageScript += '';
pageScript += '  function handlePageSizeChange() {';
pageScript += '    currentPage = 1;';
pageScript += '    pageSize = parseInt(document.getElementById("pageSize").value) || 10;';
pageScript += '    loadComments();';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Escape HTML ========== */';
pageScript += '  function escapeHtml(str) {';
pageScript += '    if (!str) return "";';
pageScript += '    const div = document.createElement("div");';
pageScript += '    div.textContent = str;';
pageScript += '    return div.innerHTML;';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Init ========== */';
pageScript += '  document.addEventListener("DOMContentLoaded", function() {';
pageScript += '    if (initialComments && initialComments.length > 0) {';
pageScript += '      renderComments(initialComments);';
pageScript += '      document.getElementById("commentCount").textContent = "共 " + initialTotal + " 条记录";';
pageScript += '      var totalPages = Math.ceil(initialTotal / pageSize);';
pageScript += '      renderPagination("paginationContainer", 1, totalPages, function(page) {';
pageScript += '        currentPage = page;';
pageScript += '        loadComments();';
pageScript += '      });';
pageScript += '    } else {';
pageScript += '      document.getElementById("commentsBody").innerHTML = "<tr><td colspan=\\"7\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x1F4ED;</div><p>暂无评论数据</p></div></td></tr>";';
pageScript += '      document.getElementById("commentCount").textContent = "共 0 条记录";';
pageScript += '    }';
pageScript += '    initTableSort(document.getElementById("commentsTable"), function(field, dir) {';
pageScript += '      currentSort = field;';
pageScript += '      currentDir = dir;';
pageScript += '      currentPage = 1;';
pageScript += '      loadComments();';
pageScript += '    });';
pageScript += '  });';
pageScript += '</script>';
%>
<%- include('layout', { pageTitle: '评论管理', activeMenu: 'comments', body: body, pageScript: pageScript }) %>
