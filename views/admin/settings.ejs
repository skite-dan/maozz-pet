<%# settings.ejs - 系统设置 %>
<%
var body = '';

body += '<div class="page-header">';
body += '  <h1>&#x2699; 系统设置</h1>';
body += '  <p>管理网站基础配置信息，修改后点击保存生效</p>';
body += '</div>';

body += '<div class="settings-container" id="settingsContainer">';
body += '  <div class="loading-spinner" style="margin:60px auto;"></div>';
body += '</div>';

var pageScript = '';
pageScript += '<script>';
pageScript += '  /* ========== Setting Groups Config ========== */';
pageScript += '  var groupConfig = {';
pageScript += '    "general": { title: "网站基础信息", icon: "&#x1F310;", desc: "网站名称、描述、注册等基础配置" },';
pageScript += '    "seo": { title: "SEO优化", icon: "&#x1F50D;", desc: "搜索引擎优化相关设置" },';
pageScript += '    "adsense": { title: "广告设置", icon: "&#x1F4B0;", desc: "Google AdSense广告投放配置" },';
pageScript += '    "display": { title: "显示设置", icon: "&#x1F3A8;", desc: "分页、头像等展示配置" },';
pageScript += '    "contact": { title: "联系方式", icon: "&#x1F4E7;", desc: "客服、商务合作等联系信息" },';
pageScript += '    "security": { title: "安全设置", icon: "&#x1F512;", desc: "登录、验证码等安全策略" },';
pageScript += '    "other": { title: "其他设置", icon: "&#x1F4CB;", desc: "其他未分类配置项" }';
pageScript += '  };';
pageScript += '';
pageScript += '  /* ========== Load Settings ========== */';
pageScript += '  async function loadSettings() {';
pageScript += '    const res = await adminFetch("/api/admin/settings");';
pageScript += '    if (!res || !res.ok) {';
pageScript += '      document.getElementById("settingsContainer").innerHTML = "<div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div>";';
pageScript += '      return;';
pageScript += '    }';
pageScript += '    const data = await res.json();';
pageScript += '    if (data.code === 200 && data.data) {';
pageScript += '      if (data.data.length === 0) {';
pageScript += '        document.getElementById("settingsContainer").innerHTML = "<div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x2699;</div><p>暂无设置数据</p></div>";';
pageScript += '      } else {';
pageScript += '        renderSettings(data.data);';
pageScript += '      }';
pageScript += '    } else {';
pageScript += '      document.getElementById("settingsContainer").innerHTML = "<div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div>";';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Group Settings ========== */';
pageScript += '  function groupSettings(settings) {';
pageScript += '    var groups = {};';
pageScript += '    settings.forEach(function(s) {';
pageScript += '      var group = s.setting_group || "other";';
pageScript += '      if (!groupConfig[group]) group = "other";';
pageScript += '      if (!groups[group]) groups[group] = [];';
pageScript += '      groups[group].push(s);';
pageScript += '    });';
pageScript += '    return groups;';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Detect Input Type ========== */';
pageScript += '  function detectInputType(key, value) {';
pageScript += '    if (/enabled|disabled|open|close|switch|toggle/i.test(key)) return { type: "switch" };';
pageScript += '    if (/color|theme|primary|background/i.test(key)) return { type: "color" };';
pageScript += '    if (/number|count|limit|length|size|retry|timeout/i.test(key)) return { type: "number" };';
pageScript += '    if (/email|mail/i.test(key)) return { type: "email" };';
pageScript += '    if (/url|link|logo|favicon|avatar/i.test(key)) return { type: "url" };';
pageScript += '    if (/phone|tel|mobile/i.test(key)) return { type: "tel" };';
pageScript += '    if (/description|content|intro|about|remark/i.test(key)) return { type: "textarea", rows: 3 };';
pageScript += '    if (/keywords|tags|types/i.test(key)) return { type: "textarea", rows: 2 };';
pageScript += '    if (value && value.length > 50) return { type: "textarea", rows: 2 };';
pageScript += '    return { type: "text" };';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Build Input HTML ========== */';
pageScript += '  function buildInput(s, typeInfo) {';
pageScript += '    var key = escapeHtml(s.setting_key);';
pageScript += '    var val = escapeHtml(s.setting_value || "");';
pageScript += '    var type = typeInfo.type;';
pageScript += '    if (type === "switch") {';
pageScript += '      var isOn = val === "1" || val === "true" || val === "on" || val === "yes";';
pageScript += '      return "<label class=\\"switch\\">" +';
pageScript += '        "<input type=\\"checkbox\\" data-key=\\"" + key + "\\"" + (isOn ? " checked" : "") + " onchange=\\"markChanged(this)\\">" +';
pageScript += '        "<span class=\\"switch-slider\\"></span>" +';
pageScript += '        "</label>";';
pageScript += '    }';
pageScript += '    if (type === "color") {';
pageScript += '      return "<div class=\\"color-input-wrapper\\">" +';
pageScript += '        "<input type=\\"color\\" class=\\"color-picker\\" data-key=\\"" + key + "\\" value=\\"" + (val || "#ff6b35") + "\\" onchange=\\"markChanged(this)\\">" +';
pageScript += '        "<input type=\\"text\\" class=\\"form-input color-text\\" data-key=\\"" + key + "\\" value=\\"" + val + "\\" oninput=\\"syncColor(this)\\" onchange=\\"markChanged(this)\\">" +';
pageScript += '        "</div>";';
pageScript += '    }';
pageScript += '    if (type === "textarea") {';
pageScript += '      return "<textarea class=\\"form-input\\" data-key=\\"" + key + "\\" rows=\\"" + (typeInfo.rows || 3) + "\\" oninput=\\"markChanged(this)\\">" + val + "</textarea>";';
pageScript += '    }';
pageScript += '    return "<input type=\\"" + type + "\\" class=\\"form-input\\" data-key=\\"" + key + "\\" value=\\"" + val + "\\" oninput=\\"markChanged(this)\\">";';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Mark Changed ========== */';
pageScript += '  function markChanged(el) {';
pageScript += '    var item = el.closest(".setting-row");';
pageScript += '    if (item) item.classList.add("changed");';
pageScript += '    updateSaveButton();';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Sync Color ========== */';
pageScript += '  function syncColor(el) {';
pageScript += '    var wrapper = el.closest(".color-input-wrapper");';
pageScript += '    if (wrapper) {';
pageScript += '      var picker = wrapper.querySelector(".color-picker");';
pageScript += '      if (picker) picker.value = el.value;';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Update Save Button ========== */';
pageScript += '  function updateSaveButton() {';
pageScript += '    var changed = document.querySelectorAll(".setting-row.changed").length;';
pageScript += '    var btn = document.getElementById("globalSaveBtn");';
pageScript += '    if (btn) {';
pageScript += '      btn.textContent = changed > 0 ? "&#x1F4BE; 保存修改 (" + changed + ")" : "&#x1F4BE; 保存设置";';
pageScript += '      btn.classList.toggle("btn-primary", changed > 0);';
pageScript += '      btn.classList.toggle("btn-outline", changed === 0);';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Render Settings ========== */';
pageScript += '  function renderSettings(settings) {';
pageScript += '    var container = document.getElementById("settingsContainer");';
pageScript += '    if (!settings || settings.length === 0) {';
pageScript += '      container.innerHTML = "<div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x2699;</div><p>暂无设置项</p></div>";';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    var groups = groupSettings(settings);';
pageScript += '    var html = "";';
pageScript += '';
pageScript += '    Object.keys(groupConfig).forEach(function(groupKey) {';
pageScript += '      var items = groups[groupKey];';
pageScript += '      if (!items || items.length === 0) return;';
pageScript += '      var cfg = groupConfig[groupKey];';
pageScript += '';
pageScript += '      html += "<div class=\\"settings-card\\">";';
pageScript += '      html += "<div class=\\"settings-card-header\\">";';
pageScript += '      html += "<div class=\\"settings-card-icon\\">" + cfg.icon + "</div>";';
pageScript += '      html += "<div class=\\"settings-card-title\\">";';
pageScript += '      html += "<h3>" + cfg.title + "</h3>";';
pageScript += '      html += "<p>" + cfg.desc + "</p>";';
pageScript += '      html += "</div>";';
pageScript += '      html += "</div>";';
pageScript += '      html += "<div class=\\"settings-card-body\\">";';
pageScript += '';
pageScript += '      items.forEach(function(s) {';
pageScript += '        var typeInfo = detectInputType(s.setting_key, s.setting_value);';
pageScript += '        html += "<div class=\\"setting-row\\" data-key=\\"" + escapeHtml(s.setting_key) + "\\">";';
pageScript += '        html += "<div class=\\"setting-meta\\">";';
pageScript += '        html += "<label class=\\"setting-name\\">" + escapeHtml(s.description || s.setting_name || s.setting_key) + "</label>";';
pageScript += '        html += "<code class=\\"setting-key-tag\\">" + escapeHtml(s.setting_key) + "</code>";';
pageScript += '        html += "</div>";';
pageScript += '        html += "<div class=\\"setting-control\\">" + buildInput(s, typeInfo) + "</div>";';
pageScript += '        html += "</div>";';
pageScript += '      });';
pageScript += '';
pageScript += '      html += "</div>";';
pageScript += '      html += "</div>";';
pageScript += '    });';
pageScript += '';
pageScript += '    html += "<div class=\\"settings-footer\\">";';
pageScript += '    html += "<button id=\\"globalSaveBtn\\" class=\\"btn btn-primary\\" onclick=\\"saveSettings()\\">&#x1F4BE; 保存设置</button>";';
pageScript += '    html += "<span class=\\"save-hint\\">&#x2139; 修改后的设置项会高亮显示，点击保存后生效</span>";';
pageScript += '    html += "</div>";';
pageScript += '';
pageScript += '    container.innerHTML = html;';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Save Settings ========== */';
pageScript += '  async function saveSettings() {';
pageScript += '    var inputs = document.querySelectorAll("#settingsContainer input[data-key], #settingsContainer textarea[data-key]");';
pageScript += '    var settings = {};';
pageScript += '    inputs.forEach(function(el) {';
pageScript += '      var key = el.dataset.key;';
pageScript += '      if (el.type === "checkbox") {';
pageScript += '        settings[key] = el.checked ? "1" : "0";';
pageScript += '      } else {';
pageScript += '        settings[key] = el.value;';
pageScript += '      }';
pageScript += '    });';
pageScript += '';
pageScript += '    var btn = document.getElementById("globalSaveBtn");';
pageScript += '    if (btn) { btn.textContent = "保存中..."; btn.disabled = true; }';
pageScript += '';
pageScript += '    const res = await adminFetch("/api/admin/settings", {';
pageScript += '      method: "PUT",';
pageScript += '      body: JSON.stringify({ settings: settings })';
pageScript += '    });';
pageScript += '';
pageScript += '    if (btn) { btn.disabled = false; }';
pageScript += '    if (!res) return;';
pageScript += '    const data = await res.json();';
pageScript += '    if (data.code === 200) {';
pageScript += '      showToast("设置已保存", "success");';
pageScript += '      document.querySelectorAll(".setting-row.changed").forEach(function(el) { el.classList.remove("changed"); });';
pageScript += '      updateSaveButton();';
pageScript += '    } else {';
pageScript += '      showToast(data.message || "保存失败", "error");';
pageScript += '      updateSaveButton();';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Escape HTML ========== */';
pageScript += '  function escapeHtml(str) {';
pageScript += '    if (!str) return "";';
pageScript += '    var div = document.createElement("div");';
pageScript += '    div.textContent = str;';
pageScript += '    return div.innerHTML;';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Init ========== */';
pageScript += '  document.addEventListener("DOMContentLoaded", function() {';
pageScript += '    loadSettings();';
pageScript += '  });';
pageScript += '</script>';
%>
<%- include('layout', { pageTitle: '系统设置', activeMenu: 'settings', body: body, pageScript: pageScript }) %>
