<%# posts.ejs - 帖子管理 %>
<%
var body = '';

body += '<div class="page-header">';
body += '  <h1>帖子管理</h1>';
body += '  <p>管理平台所有帖子内容，审核与维护</p>';
body += '</div>';

body += '<!-- 筛选栏 -->';
body += '<div class="filter-bar">';
body += '  <select id="filterStatus" onchange="handleFilter()">';
body += '    <option value="">全部状态</option>';
body += '    <option value="published">已发布</option>';
body += '    <option value="draft">草稿</option>';
body += '    <option value="hidden">已隐藏</option>';
body += '    <option value="deleted">已删除</option>';
body += '  </select>';
body += '  <select id="filterType" onchange="handleFilter()">';
body += '    <option value="">全部类型</option>';
body += '    <option value="forum">论坛</option>';
body += '    <option value="wiki">百科</option>';
body += '    <option value="story">故事</option>';
body += '  </select>';
body += '  <div class="search-input">';
body += '    <input type="text" id="searchKeyword" placeholder="搜索帖子标题..." onkeydown="if(event.key===\'Enter\')handleFilter()">';
body += '  </div>';
body += '  <select id="pageSize" onchange="handlePageSizeChange()">';
body += '    <option value="10">10条/页</option>';
body += '    <option value="30">30条/页</option>';
body += '    <option value="50">50条/页</option>';
body += '  </select>';
body += '  <button class="btn btn-primary" onclick="handleFilter()">&#x1F50D; 搜索</button>';
body += '  <button class="btn btn-outline" onclick="resetFilter()">&#x21BA; 重置</button>';
body += '</div>';

body += '<!-- 帖子表格 -->';
body += '<div class="card">';
body += '  <div class="card-header">';
body += '    <h2>帖子列表</h2>';
body += '    <span id="postCount" style="font-size:13px;color:#94a3b8;"></span>';
body += '  </div>';
body += '  <div class="table-wrapper">';
body += '    <table class="data-table" id="postsTable">';
body += '      <thead>';
body += '        <tr>';
body += '          <th data-sort="id">ID <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="title">标题 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th>作者</th>';
body += '          <th>类型</th>';
body += '          <th>分类</th>';
body += '          <th data-sort="view_count">浏览量 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="like_count">点赞数 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="status">状态 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="created_at">创建时间 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th>操作</th>';
body += '        </tr>';
body += '      </thead>';
body += '      <tbody id="postsBody">';
body += '        <tr><td colspan="10"><div class="loading-spinner"></div></td></tr>';
body += '      </tbody>';
body += '    </table>';
body += '  </div>';
body += '  <div id="paginationContainer"></div>';
body += '</div>';

var pageScript = '';
pageScript += '<script>';
pageScript += '  let currentPage = 1;';
pageScript += '  let pageSize = 10;';
pageScript += '  let currentSort = "";';
pageScript += '  let currentDir = "";';
pageScript += '  var initialPosts = ' + JSON.stringify((initialData && initialData.posts) ? initialData.posts : []) + ';';
pageScript += '  var initialTotal = ' + ((initialData && initialData.total) ? initialData.total : 0) + ';';
pageScript += '';
pageScript += '  /* ========== Load Posts ========== */';
pageScript += '  async function loadPosts() {';
pageScript += '    const status = document.getElementById("filterStatus").value;';
pageScript += '    const type = document.getElementById("filterType").value;';
pageScript += '    const keyword = document.getElementById("searchKeyword").value.trim();';
pageScript += '    pageSize = parseInt(document.getElementById("pageSize").value) || 10;';
pageScript += '';
pageScript += '    let url = "/api/admin/posts?page=" + currentPage + "&limit=" + pageSize;';
pageScript += '    if (status !== "") url += "&status=" + status;';
pageScript += '    if (type !== "") url += "&type=" + type;';
pageScript += '    if (keyword) url += "&keyword=" + encodeURIComponent(keyword);';
pageScript += '    if (currentSort) url += "&sortBy=" + currentSort + "&sortDir=" + currentDir;';
pageScript += '';
pageScript += '    const res = await adminFetch(url);';
pageScript += '    if (!res || !res.ok) {';
pageScript += '      var tbody = document.getElementById("postsBody");';
pageScript += '      tbody.innerHTML = "<tr><td colspan=\\"10\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div></td></tr>";';
pageScript += '      document.getElementById("postCount").textContent = "";';
pageScript += '      return;';
pageScript += '    }';
pageScript += '    const data = await res.json();';
pageScript += '';
pageScript += '    if (data.code === 200 && data.data) {';
pageScript += '      var list = data.data.list || data.data.posts || [];';
pageScript += '      if (list.length === 0) {';
pageScript += '        document.getElementById("postsBody").innerHTML = "<tr><td colspan=\\"10\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x1F4ED;</div><p>暂无帖子数据</p></div></td></tr>";';
pageScript += '        document.getElementById("postCount").textContent = "共 0 条记录";';
pageScript += '        document.getElementById("paginationContainer").innerHTML = "";';
pageScript += '      } else {';
pageScript += '        renderPosts(list);';
pageScript += '        const total = data.data.total || 0;';
pageScript += '        const totalPages = Math.ceil(total / pageSize);';
pageScript += '        document.getElementById("postCount").textContent = "共 " + total + " 条记录";';
pageScript += '        renderPagination("paginationContainer", currentPage, totalPages, function(page) {';
pageScript += '          currentPage = page;';
pageScript += '          loadPosts();';
pageScript += '        });';
pageScript += '      }';
pageScript += '    } else {';
pageScript += '      var tbody2 = document.getElementById("postsBody");';
pageScript += '      tbody2.innerHTML = "<tr><td colspan=\\"10\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div></td></tr>";';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Render Posts ========== */';
pageScript += '  function renderPosts(posts) {';
pageScript += '    const tbody = document.getElementById("postsBody");';
pageScript += '    if (!posts || posts.length === 0) {';
pageScript += '      tbody.innerHTML = \'<tr><td colspan="10"><div class="empty-state"><div class="empty-icon">&#x1F4ED;</div><p>暂无帖子数据</p></div></td></tr>\';';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    const statusMap = { "published": { text: "已发布", cls: "success" }, "draft": { text: "草稿", cls: "warning" }, "hidden": { text: "已隐藏", cls: "default" }, "deleted": { text: "已删除", cls: "danger" }, "default": { text: "未知", cls: "default" } };';
pageScript += '    const typeMap = { "forum": { text: "论坛", cls: "info" }, "wiki": { text: "百科", cls: "success" }, "story": { text: "故事", cls: "warning" }, "default": { text: "其他", cls: "default" } };';
pageScript += '';
pageScript += '    tbody.innerHTML = posts.map(p => \'<tr>\' +';
pageScript += '      \'<td class="cell-id">\' + (p.id || \'-\') + \'</td>\' +';
pageScript += '      \'<td class="cell-title" title="\' + escapeHtml(p.title || \'\') + \'">\' + escapeHtml(p.title || \'-\') + \'</td>\' +';
pageScript += '      \'<td>\' + escapeHtml(p.authorName || p.author_username || p.username || \'-\') + \'</td>\' +';
pageScript += '      \'<td>\' + statusTag(p.type, typeMap) + \'</td>\' +';
pageScript += '      \'<td style="color:#64748b;">\' + escapeHtml(p.category || \'-\') + \'</td>\' +';
pageScript += '      \'<td>\' + (p.view_count || 0) + \'</td>\' +';
pageScript += '      \'<td>\' + (p.like_count || 0) + \'</td>\' +';
pageScript += '      \'<td>\' + statusTag(p.status, statusMap) + \'</td>\' +';
pageScript += '      \'<td style="font-size:12px;color:#64748b;white-space:nowrap;">\' + formatDate(p.created_at || p.createdAt) + \'</td>\' +';
pageScript += '      \'<td>\' +';
pageScript += '        \'<div style="display:flex;gap:4px;flex-wrap:nowrap;">\' +';
pageScript += '        \'<button class="btn btn-sm btn-outline" onclick="viewPost(\' + p.id + \')" title="查看">&#x1F441;</button>\' +';
pageScript += '        \'<button class="btn btn-sm \' + (p.status === 2 ? \'btn-success\' : \'btn-warning\') + \'"\' +';
pageScript += '        \' onclick="togglePostVisibility(\' + p.id + \', \' + p.status + \')" title="\' + (p.status === 2 ? \'显示\' : \'隐藏\') + \'">\' +';
pageScript += '        (p.status === 2 ? \'&#x1F441; 显示\' : \'&#x1F6AE; 隐藏\') +';
pageScript += '        \'</button>\' +';
pageScript += '        \'<button class="btn btn-sm btn-danger" onclick="deletePost(\' + p.id + \')" title="删除">&#x1F5D1;</button>\' +';
pageScript += '        \'</div>\' +';
pageScript += '      \'</td>\' +';
pageScript += '      \'</tr>\').join(\'\');';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== View Post ========== */';
pageScript += '  function viewPost(postId) {';
pageScript += '    window.open("/posts/" + postId, "_blank");';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Toggle Post Visibility ========== */';
pageScript += '  async function togglePostVisibility(postId, currentStatus) {';
pageScript += '    const newStatus = currentStatus === 2 ? 1 : 2;';
pageScript += '    const action = newStatus === 2 ? "隐藏" : "显示";';
pageScript += '';
pageScript += '    showConfirm(';
pageScript += '      action + "帖子",';
pageScript += '      "确定要" + action + "该帖子吗？",';
pageScript += '      async function() {';
pageScript += '        const res = await adminFetch("/api/admin/posts/" + postId + "/status", {';
pageScript += '          method: "PUT",';
pageScript += '          body: JSON.stringify({ status: newStatus })';
pageScript += '        });';
pageScript += '        if (!res) return;';
pageScript += '        const data = await res.json();';
pageScript += '        if (data.code === 200) {';
pageScript += '          showToast("帖子已" + action, "success");';
pageScript += '          loadPosts();';
pageScript += '        } else {';
pageScript += '          showToast(data.message || "操作失败", "error");';
pageScript += '        }';
pageScript += '      }';
pageScript += '    );';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Delete Post (soft delete) ========== */';
pageScript += '  async function deletePost(postId) {';
pageScript += '    showConfirm(';
pageScript += '      "删除帖子",';
pageScript += '      "确定要删除该帖子吗？此操作将进行软删除，帖子将标记为已删除状态。",';
pageScript += '      async function() {';
pageScript += '        const res = await adminFetch("/api/admin/posts/" + postId, {';
pageScript += '          method: "DELETE"';
pageScript += '        });';
pageScript += '        if (!res) return;';
pageScript += '        const data = await res.json();';
pageScript += '        if (data.code === 200) {';
pageScript += '          showToast("帖子已删除", "success");';
pageScript += '          loadPosts();';
pageScript += '        } else {';
pageScript += '          showToast(data.message || "删除失败", "error");';
pageScript += '        }';
pageScript += '      }';
pageScript += '    );';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Filter ========== */';
pageScript += '  function handleFilter() {';
pageScript += '    currentPage = 1;';
pageScript += '    loadPosts();';
pageScript += '  }';
pageScript += '';
pageScript += '  function resetFilter() {';
pageScript += '    document.getElementById("filterStatus").value = "";';
pageScript += '    document.getElementById("filterType").value = "";';
pageScript += '    document.getElementById("searchKeyword").value = "";';
pageScript += '    document.getElementById("pageSize").value = "10";';
pageScript += '    currentPage = 1;';
pageScript += '    pageSize = 10;';
pageScript += '    currentSort = "";';
pageScript += '    currentDir = "";';
pageScript += '    loadPosts();';
pageScript += '  }';
pageScript += '';
pageScript += '  function handlePageSizeChange() {';
pageScript += '    currentPage = 1;';
pageScript += '    pageSize = parseInt(document.getElementById("pageSize").value) || 10;';
pageScript += '    loadPosts();';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Escape HTML ========== */';
pageScript += '  function escapeHtml(str) {';
pageScript += '    if (!str) return "";';
pageScript += '    const div = document.createElement("div");';
pageScript += '    div.textContent = str;';
pageScript += '    return div.innerHTML;';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Init ========== */';
pageScript += '  document.addEventListener("DOMContentLoaded", function() {';
pageScript += '    if (initialPosts && initialPosts.length > 0) {';
pageScript += '      renderPosts(initialPosts);';
pageScript += '      document.getElementById("postCount").textContent = "共 " + initialTotal + " 条记录";';
pageScript += '      var totalPages = Math.ceil(initialTotal / pageSize);';
pageScript += '      renderPagination("paginationContainer", 1, totalPages, function(page) {';
pageScript += '        currentPage = page;';
pageScript += '        loadPosts();';
pageScript += '      });';
pageScript += '    } else {';
pageScript += '      document.getElementById("postsBody").innerHTML = "<tr><td colspan=\\"10\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x1F4ED;</div><p>暂无帖子数据</p></div></td></tr>";';
pageScript += '      document.getElementById("postCount").textContent = "共 0 条记录";';
pageScript += '    }';
pageScript += '    initTableSort(document.getElementById("postsTable"), function(field, dir) {';
pageScript += '      currentSort = field;';
pageScript += '      currentDir = dir;';
pageScript += '      currentPage = 1;';
pageScript += '      loadPosts();';
pageScript += '    });';
pageScript += '  });';
pageScript += '</script>';
%>
<%- include('layout', { pageTitle: '帖子管理', activeMenu: 'posts', body: body, pageScript: pageScript }) %>
