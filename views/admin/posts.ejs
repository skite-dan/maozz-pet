<%# posts.ejs - 帖子管理 %>
<%
var body = '';

body += '<div class="page-header">';
body += '  <h1>帖子管理</h1>';
body += '  <p>管理平台所有帖子内容，审核与维护</p>';
body += '</div>';

body += '<!-- 筛选栏 -->';
body += '<div class="filter-bar">';
body += '  <select id="filterStatus" onchange="handleFilter()">';
body += '    <option value="">全部状态</option>';
body += '    <option value="published">已发布</option>';
body += '    <option value="draft">草稿</option>';
body += '    <option value="hidden">已隐藏</option>';
body += '    <option value="deleted">已删除</option>';
body += '  </select>';
body += '  <select id="filterType" onchange="handleFilter()">';
body += '    <option value="">全部类型</option>';
body += '    <option value="forum">论坛</option>';
body += '    <option value="wiki">百科</option>';
body += '    <option value="story">故事</option>';
body += '  </select>';
body += '  <div class="search-input">';
body += '    <input type="text" id="searchKeyword" placeholder="搜索帖子标题..." onkeydown="if(event.key===\'Enter\')handleFilter()">';
body += '  </div>';
body += '  <select id="pageSize" onchange="handlePageSizeChange()">';
body += '    <option value="10">10条/页</option>';
body += '    <option value="30">30条/页</option>';
body += '    <option value="50">50条/页</option>';
body += '  </select>';
body += '  <button class="btn btn-primary" onclick="handleFilter()">&#x1F50D; 搜索</button>';
body += '  <button class="btn btn-outline" onclick="resetFilter()">&#x21BA; 重置</button>';
body += '</div>';

body += '<!-- 帖子表格 -->';
body += '<div class="card">';
body += '  <div class="card-header">';
body += '    <h2>帖子列表</h2>';
body += '    <span id="postCount" style="font-size:13px;color:#94a3b8;"></span>';
body += '  </div>';
body += '  <div class="table-wrapper">';
body += '    <table class="data-table" id="postsTable">';
body += '      <thead>';
body += '        <tr>';
body += '          <th data-sort="id">ID <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="title">标题 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th>作者</th>';
body += '          <th>类型</th>';
body += '          <th>分类</th>';
body += '          <th data-sort="view_count">浏览量 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="like_count">点赞数 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="status">状态 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="created_at">创建时间 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th>操作</th>';
body += '        </tr>';
body += '      </thead>';
body += '      <tbody id="postsBody">';
body += '        <tr><td colspan="10"><div class="loading-spinner"></div></td></tr>';
body += '      </tbody>';
body += '    </table>';
body += '  </div>';
body += '  <div id="paginationContainer"></div>';
body += '</div>';

// 查看帖子详情弹窗
body += '<div class="modal" id="viewPostModal">';
body += '  <div class="modal-overlay" onclick="closeViewModal()"></div>';
body += '  <div class="modal-content" style="max-width:720px;max-height:85vh;">';
body += '    <div class="modal-header">';
body += '      <h3>帖子详情</h3>';
body += '      <button class="modal-close" onclick="closeViewModal()">&times;</button>';
body += '    </div>';
body += '    <div class="modal-body" id="viewPostBody" style="overflow-y:auto;">';
body += '      <div class="loading-spinner"></div>';
body += '    </div>';
body += '    <div class="modal-footer">';
body += '      <button class="btn btn-outline" onclick="closeViewModal()">关闭</button>';
body += '      <button class="btn btn-primary" id="viewEditBtn" onclick="openEditFromView()">编辑</button>';
body += '    </div>';
body += '  </div>';
body += '</div>';

// 编辑帖子弹窗
body += '<div class="modal" id="editPostModal">';
body += '  <div class="modal-overlay" onclick="closeEditModal()"></div>';
body += '  <div class="modal-content" style="max-width:640px;max-height:90vh;">';
body += '    <div class="modal-header">';
body += '      <h3>编辑帖子</h3>';
body += '      <button class="modal-close" onclick="closeEditModal()">&times;</button>';
body += '    </div>';
body += '    <div class="modal-body" style="overflow-y:auto;">';
body += '      <input type="hidden" id="editPostId">';
body += '      <div class="form-group">';
body += '        <label class="form-label">标题 <span style="color:#ef4444;">*</span></label>';
body += '        <input type="text" class="form-input" id="editPostTitle" placeholder="帖子标题">';
body += '      </div>';
body += '      <div class="form-group">';
body += '        <label class="form-label">内容 <span style="color:#ef4444;">*</span></label>';
body += '        <div id="editPostToolbar" style="border:1px solid #e2e8f0;border-bottom:none;border-radius:8px 8px 0 0;background:#f8fafc;"></div>';
body += '        <div id="editPostEditor" style="border:1px solid #e2e8f0;border-radius:0 0 8px 8px;height:300px;overflow-y:auto;background:#fff;"></div>';
body += '        <textarea id="editPostContent" style="display:none;"></textarea>';
body += '      </div>';
body += '      <div class="form-group">';
body += '        <label class="form-label">类型</label>';
body += '        <select class="form-input" id="editPostType">';
body += '          <option value="forum">论坛</option>';
body += '          <option value="wiki">百科</option>';
body += '          <option value="story">故事</option>';
body += '        </select>';
body += '      </div>';
body += '      <div class="form-group">';
body += '        <label class="form-label">分类</label>';
body += '        <input type="text" class="form-input" id="editPostCategory" placeholder="分类">';
body += '      </div>';
body += '      <div class="form-group">';
body += '        <label class="form-label">标签</label>';
body += '        <input type="text" class="form-input" id="editPostTags" placeholder="标签，用逗号分隔">';
body += '      </div>';
body += '      <div class="form-group">';
body += '        <label class="form-label">状态</label>';
body += '        <select class="form-input" id="editPostStatus">';
body += '          <option value="published">已发布</option>';
body += '          <option value="draft">草稿</option>';
body += '          <option value="hidden">已隐藏</option>';
body += '          <option value="deleted">已删除</option>';
body += '        </select>';
body += '      </div>';
body += '      <div class="form-error" id="editPostError"></div>';
body += '    </div>';
body += '    <div class="modal-footer">';
body += '      <button class="btn btn-outline" onclick="closeEditModal()">取消</button>';
body += '      <button class="btn btn-primary" onclick="savePostEdit()">保存</button>';
body += '    </div>';
body += '  </div>';
body += '</div>';

var pageScript = '';
pageScript += '<script>';
pageScript += '  var currentPage = 1;';
pageScript += '  var pageSize = 10;';
pageScript += '  var currentSort = "";';
pageScript += '  var currentDir = "";';
pageScript += '  var currentViewPostId = null;';
pageScript += '  var _postList = [];';
pageScript += '  var _postTotal = 0;';
pageScript += '  var _currentFilterStatus = "";';
pageScript += '  var _currentFilterType = "";';
pageScript += '  var _currentKeyword = "";';
pageScript += '  var _isLoading = false;';
pageScript += '  var _tableSortField = "";';
pageScript += '  var _tableSortDir = "asc";';
pageScript += '  var _statusMap = { published: { text: "已发布", cls: "success" }, draft: { text: "草稿", cls: "warning" }, hidden: { text: "已隐藏", cls: "default" }, deleted: { text: "已删除", cls: "danger" } };';
pageScript += '  var _typeMap = { forum: { text: "论坛", cls: "info" }, wiki: { text: "百科", cls: "success" }, story: { text: "故事", cls: "warning" } };';
pageScript += '  var initialPosts = ' + JSON.stringify((initialData && initialData.posts) ? initialData.posts : []) + ';';
pageScript += '  var initialTotal = ' + ((initialData && initialData.total) ? initialData.total : 0) + ';';
pageScript += '';
pageScript += '  /* ========== Load Posts ========== */';
pageScript += '  async function loadPosts() {';
pageScript += '    var status = document.getElementById("filterStatus").value;';
pageScript += '    var type = document.getElementById("filterType").value;';
pageScript += '    var keyword = document.getElementById("searchKeyword").value.trim();';
pageScript += '    pageSize = parseInt(document.getElementById("pageSize").value) || 10;';
pageScript += '';
pageScript += '    var url = "/api/admin/posts?page=" + currentPage + "&limit=" + pageSize;';
pageScript += '    if (status !== "") url += "&status=" + status;';
pageScript += '    if (type !== "") url += "&type=" + type;';
pageScript += '    if (keyword) url += "&keyword=" + encodeURIComponent(keyword);';
pageScript += '    if (currentSort) url += "&sortBy=" + currentSort + "&sortDir=" + currentDir;';
pageScript += '';
pageScript += '    var res = await adminFetch(url);';
pageScript += '    if (!res || !res.ok) {';
pageScript += '      var tbody = document.getElementById("postsBody");';
pageScript += '      tbody.innerHTML = \'<tr><td colspan="10"><div class="empty-state"><div class="empty-icon">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div></td></tr>\';';
      pageScript += '      document.getElementById("postCount").textContent = "";';
      pageScript += '      return;';
      pageScript += '    }';
      pageScript += '    var data = await res.json();';
      pageScript += '';
      pageScript += '    if (data.code === 200 && data.data) {';
      pageScript += '      var list = data.data.list || data.data.posts || [];';
      pageScript += '      if (list.length === 0) {';
      pageScript += '        document.getElementById("postsBody").innerHTML = \'<tr><td colspan="10"><div class="empty-state"><div class="empty-icon">&#x1F4ED;</div><p>暂无帖子数据</p></div></td></tr>\';';
      pageScript += '        document.getElementById("postCount").textContent = "共 0 条记录";';
      pageScript += '        document.getElementById("paginationContainer").innerHTML = "";';
      pageScript += '      } else {';
      pageScript += '        renderPosts(list);';
      pageScript += '        var total = data.data.total || 0;';
      pageScript += '        var totalPages = Math.ceil(total / pageSize);';
      pageScript += '        document.getElementById("postCount").textContent = "共 " + total + " 条记录";';
      pageScript += '        renderPagination("paginationContainer", currentPage, totalPages, function(page) {';
      pageScript += '          currentPage = page;';
      pageScript += '          loadPosts();';
      pageScript += '        });';
      pageScript += '      }';
      pageScript += '    } else {';
      pageScript += '      var tbody2 = document.getElementById("postsBody");';
      pageScript += '      tbody2.innerHTML = \'<tr><td colspan="10"><div class="empty-state"><div class="empty-icon">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div></td></tr>\';';
      pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Render Posts ========== */';
pageScript += '  function renderPosts(posts) {';
pageScript += '    var tbody = document.getElementById("postsBody");';
pageScript += '    if (!posts || posts.length === 0) {';
pageScript += '      tbody.innerHTML = \'<tr><td colspan="10"><div class="empty-state"><div class="empty-icon">&#x1F4ED;</div><p>暂无帖子数据</p></div></td></tr>\';';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    var statusMap = { "published": { text: "已发布", cls: "success" }, "draft": { text: "草稿", cls: "warning" }, "hidden": { text: "已隐藏", cls: "default" }, "deleted": { text: "已删除", cls: "danger" }, "default": { text: "未知", cls: "default" } };';
pageScript += '    var typeMap = { "forum": { text: "论坛", cls: "info" }, "wiki": { text: "百科", cls: "success" }, "story": { text: "故事", cls: "warning" }, "default": { text: "其他", cls: "default" } };';
pageScript += '';
pageScript += '    tbody.innerHTML = posts.map(p => \'<tr>\' +';
pageScript += '      \'<td class="cell-id">\' + (p.id || \'-\') + \'</td>\' +';
pageScript += '      \'<td class="cell-title" title="\' + escapeHtml(p.title || \'\') + \'">\' + escapeHtml(p.title || \'-\') + \'</td>\' +';
pageScript += '      \'<td>\' + escapeHtml(p.username || p.authorName || p.author_username || \'-\') + \'</td>\' +';
pageScript += '      \'<td>\' + statusTag(p.post_type || p.type, typeMap) + \'</td>\' +';
pageScript += '      \'<td style="color:#64748b;">\' + escapeHtml(p.category || \'-\') + \'</td>\' +';
pageScript += '      \'<td>\' + (p.view_count || 0) + \'</td>\' +';
pageScript += '      \'<td>\' + (p.like_count || 0) + \'</td>\' +';
pageScript += '      \'<td>\' + statusTag(p.status, statusMap) + \'</td>\' +';
pageScript += '      \'<td style="font-size:12px;color:#64748b;white-space:nowrap;">\' + formatDate(p.created_at || p.createdAt) + \'</td>\' +';
pageScript += '      \'<td>\' +';
pageScript += '        \'<div style="display:flex;gap:4px;flex-wrap:nowrap;">\' +';
pageScript += '        \'<button class="btn btn-sm btn-outline" onclick="viewPost(\' + p.id + \')" title="查看">&#x1F441;</button>\' +';
pageScript += '        \'<button class="btn btn-sm btn-primary" onclick="editPost(\' + p.id + \')" title="编辑">&#x270F;</button>\' +';
pageScript += '        \'<button class="btn btn-sm \' + (p.status === "hidden" ? \'btn-success\' : \'btn-warning\') + \'"\' +';
pageScript += '        \' onclick="togglePostVisibility(\' + p.id + \', \' + (p.status === "hidden" ? 1 : 0) + \')" title="\' + (p.status === "hidden" ? \'显示\' : \'隐藏\') + \'">\' +';
pageScript += '        (p.status === "hidden" ? \'&#x1F441;\' : \'&#x1F6AE;\') +';
pageScript += '        \'</button>\' +';
pageScript += '        \'<button class="btn btn-sm btn-danger" onclick="deletePost(\' + p.id + \')" title="删除">&#x1F5D1;</button>\' +';
pageScript += '        \'</div>\' +';
pageScript += '      \'</td>\' +';
pageScript += '      \'</tr>\').join(\'\');';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== View Post ========== */';
pageScript += '  async function viewPost(postId) {';
pageScript += '    currentViewPostId = postId;';
pageScript += '    document.getElementById("viewPostModal").classList.add("active");';
pageScript += '    document.body.style.overflow = "hidden";';
pageScript += '    document.getElementById("viewPostBody").innerHTML = \'<div class="loading-spinner"></div>\';';
pageScript += '';
pageScript += '    var res = await adminFetch("/api/admin/posts/" + postId);';
pageScript += '    if (!res || !res.ok) {';
pageScript += '      document.getElementById("viewPostBody").innerHTML = \'<div class="empty-state"><div class="empty-icon">&#x26A0;</div><p>加载失败</p></div>\';';
pageScript += '      return;';
pageScript += '    }';
pageScript += '    var data = await res.json();';
pageScript += '    if (data.code !== 200 || !data.data) {';
pageScript += '      document.getElementById("viewPostBody").innerHTML = \'<div class="empty-state"><div class="empty-icon">&#x26A0;</div><p>帖子不存在</p></div>\';';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    var p = data.data.post;';
pageScript += '    var media = data.data.media || [];';
pageScript += '    var statusMap = { "published": "已发布", "draft": "草稿", "hidden": "已隐藏", "deleted": "已删除" };';
pageScript += '    var typeMap = { "forum": "论坛", "wiki": "百科", "story": "故事" };';
pageScript += '';
pageScript += '    var html = \'<div style="line-height:1.6;">\';';
pageScript += '    html += \'<div style="margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid #f1f5f9;">\';';
pageScript += '    html += \'<h2 style="font-size:18px;font-weight:600;color:#1e293b;margin:0 0 8px;">\' + escapeHtml(p.title) + \'</h2>\';';
pageScript += '    html += \'<div style="display:flex;gap:16px;flex-wrap:wrap;font-size:13px;color:#64748b;">\';';
pageScript += '    html += \'<span>作者：\' + escapeHtml(p.username || \'-\') + \'</span>\';';
pageScript += '    html += \'<span>类型：\' + (typeMap[p.post_type] || p.post_type || \'-\') + \'</span>\';';
pageScript += '    html += \'<span>分类：\' + escapeHtml(p.category || \'-\') + \'</span>\';';
pageScript += '    html += \'<span>状态：<span class="badge \' + (p.status === "published" ? "success" : p.status === "draft" ? "warning" : p.status === "hidden" ? "default" : "danger") + \'">\' + (statusMap[p.status] || p.status) + \'<\/span><\/span>\';';
pageScript += '    html += \'<span>浏览：\' + (p.view_count || 0) + \'</span>\';';
pageScript += '    html += \'<span>点赞：\' + (p.like_count || 0) + \'</span>\';';
pageScript += '    html += \'<span>评论：\' + (p.comment_count || 0) + \'</span>\';';
pageScript += '    html += \'<span>创建：\' + formatDate(p.created_at) + \'</span>\';';
pageScript += '    html += \'</div>\';';
pageScript += '    html += \'</div>\';';
pageScript += '';
pageScript += '    if (media.length > 0) {';
pageScript += '      html += \'<div style="margin-bottom:16px;">\';';
pageScript += '      html += \'<div style="font-size:13px;font-weight:500;color:#475569;margin-bottom:8px;">附件媒体</div>\';';
pageScript += '      html += \'<div style="display:flex;gap:8px;flex-wrap:wrap;">\';';
pageScript += '      media.forEach(m => {';
pageScript += '        if (m.media_type === "image") {';
pageScript += '          html += \'<img src="\' + m.media_url + \'" style="width:120px;height:80px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;">\';';
pageScript += '        } else {';
pageScript += '          html += \'<video src="\' + m.media_url + \'" style="width:120px;height:80px;border-radius:6px;border:1px solid #e2e8f0;" controls></video>\';';
pageScript += '        }';
pageScript += '      });';
pageScript += '      html += \'</div></div>\';';
pageScript += '    }';
pageScript += '';
pageScript += '    html += \'<div style="background:#f8fafc;padding:16px;border-radius:8px;">\';';
pageScript += '    html += \'<div style="font-size:13px;font-weight:500;color:#475569;margin-bottom:8px;">帖子内容</div>\';';
pageScript += '    html += \'<div style="color:#334155;white-space:pre-wrap;word-break:break-word;">\' + escapeHtml(p.content || \'\') + \'</div>\';';
pageScript += '    html += \'</div>\';';
pageScript += '';
pageScript += '    if (p.tags) {';
pageScript += '      html += \'<div style="margin-top:12px;"><span style="font-size:13px;color:#64748b;">标签：</span><span style="color:#334155;">\' + escapeHtml(p.tags) + \'</span></div>\';';
pageScript += '    }';
pageScript += '';
pageScript += '    html += \'</div>\';';
pageScript += '    document.getElementById("viewPostBody").innerHTML = html;';
pageScript += '  }';
pageScript += '';
pageScript += '  function closeViewModal() {';
pageScript += '    document.getElementById("viewPostModal").classList.remove("active");';
pageScript += '    document.body.style.overflow = "";';
pageScript += '    currentViewPostId = null;';
pageScript += '  }';
pageScript += '';
pageScript += '  function openEditFromView() {';
pageScript += '    if (currentViewPostId) {';
pageScript += '      closeViewModal();';
pageScript += '      setTimeout(function() { editPost(currentViewPostId); }, 200);';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== wangEditor ========== */';
pageScript += '  var _wEditor = null;';
pageScript += '  var _wToolbar = null;';
pageScript += '';
pageScript += '  function initWangEditor(htmlContent) {';
pageScript += '    if (_wEditor) { _wEditor.destroy(); _wEditor = null; }';
pageScript += '    if (_wToolbar) { _wToolbar.destroy(); _wToolbar = null; }';
pageScript += '    var editorConfig = { placeholder: "请输入帖子内容...", onChange: function(editor) { document.getElementById("editPostContent").value = editor.getHtml(); } };';
pageScript += '    _wEditor = window.wangEditor.createEditor({ selector: "#editPostEditor", html: htmlContent || "<p><br></p>", config: editorConfig, mode: "simple" });';
pageScript += '    var toolbarConfig = { excludeKeys: ["uploadVideo", "insertVideo", "uploadImage"] };';
pageScript += '    _wToolbar = window.wangEditor.createToolbar({ editor: _wEditor, selector: "#editPostToolbar", config: toolbarConfig, mode: "simple" });';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Edit Post ========== */';
pageScript += '  async function editPost(postId) {';
pageScript += '    document.getElementById("editPostId").value = postId;';
pageScript += '    document.getElementById("editPostError").style.display = "none";';
pageScript += '    document.getElementById("editPostModal").classList.add("active");';
pageScript += '    document.body.style.overflow = "hidden";';
pageScript += '';
pageScript += '    var res = await adminFetch("/api/admin/posts/" + postId);';
pageScript += '    if (!res || !res.ok) {';
pageScript += '      showToast("加载帖子失败", "error");';
pageScript += '      return;';
pageScript += '    }';
pageScript += '    var data = await res.json();';
pageScript += '    if (data.code !== 200 || !data.data) {';
pageScript += '      showToast("帖子不存在", "error");';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    var p = data.data.post;';
pageScript += '    document.getElementById("editPostTitle").value = p.title || "";';
pageScript += '    document.getElementById("editPostContent").value = p.content || "";';
pageScript += '    document.getElementById("editPostType").value = p.post_type || "forum";';
pageScript += '    document.getElementById("editPostCategory").value = p.category || "";';
pageScript += '    document.getElementById("editPostTags").value = p.tags || "";';
pageScript += '    document.getElementById("editPostStatus").value = p.status || "published";';
pageScript += '    initWangEditor(p.content || "");';
pageScript += '  }';
pageScript += '';
pageScript += '  function closeEditModal() {';
pageScript += '    document.getElementById("editPostModal").classList.remove("active");';
pageScript += '    document.body.style.overflow = "";';
pageScript += '    if (_wEditor) { _wEditor.destroy(); _wEditor = null; }';
pageScript += '    if (_wToolbar) { _wToolbar.destroy(); _wToolbar = null; }';
pageScript += '  }';
pageScript += '';
pageScript += '  async function savePostEdit() {';
pageScript += '    var postId = document.getElementById("editPostId").value;';
pageScript += '    var title = document.getElementById("editPostTitle").value.trim();';
pageScript += '    var content = document.getElementById("editPostContent").value.trim();';
pageScript += '    var post_type = document.getElementById("editPostType").value;';
pageScript += '    var category = document.getElementById("editPostCategory").value.trim();';
pageScript += '    var tags = document.getElementById("editPostTags").value.trim();';
pageScript += '    var status = document.getElementById("editPostStatus").value;';
pageScript += '    var errorEl = document.getElementById("editPostError");';
pageScript += '';
pageScript += '    if (!title) { errorEl.textContent = "标题不能为空"; errorEl.style.display = "block"; return; }';
pageScript += '    if (!content || content === "<p><br></p>") { errorEl.textContent = "内容不能为空"; errorEl.style.display = "block"; return; }';
pageScript += '';
pageScript += '    var payload = { title: title, content: content, post_type: post_type, category: category, tags: tags, status: status };';
pageScript += '    var res = await adminFetch("/api/admin/posts/" + postId, {';
pageScript += '      method: "PUT",';
pageScript += '      headers: { "Content-Type": "application/json" },';
pageScript += '      body: JSON.stringify(payload)';
pageScript += '    });';
pageScript += '    if (!res) return;';
pageScript += '    var data = await res.json();';
pageScript += '    if (data.code === 200) {';
pageScript += '      closeEditModal();';
pageScript += '      showToast("帖子更新成功", "success");';
pageScript += '      loadPosts();';
pageScript += '    } else {';
pageScript += '      errorEl.textContent = data.message || "更新失败";';
pageScript += '      errorEl.style.display = "block";';
pageScript += '    }';
pageScript += '  }';
