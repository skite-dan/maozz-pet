var pageScript = '';
pageScript += '<script>';
pageScript += '  var currentPage = 1;';
pageScript += '  var pageSize = 10;';
pageScript += '  var currentSort = "";';
pageScript += '  var currentDir = "";';
pageScript += '  var currentViewPostId = null;';
pageScript += '  var _postList = [];';
pageScript += '  var _postTotal = 0;';
pageScript += '  var _currentFilterStatus = "";';
pageScript += '  var _currentFilterType = "";';
pageScript += '  var _currentKeyword = "";';
pageScript += '  var _isLoading = false;';
pageScript += '  var _tableSortField = "";';
pageScript += '  var _tableSortDir = "asc";';
pageScript += '  var _statusMap = { published: { text: "已发布", cls: "success" }, draft: { text: "草稿", cls: "warning" }, hidden: { text: "已隐藏", cls: "default" }, deleted: { text: "已删除", cls: "danger" } };';
pageScript += '  var _typeMap = { forum: { text: "论坛", cls: "info" }, wiki: { text: "百科", cls: "success" }, story: { text: "故事", cls: "warning" } };';
pageScript += '  var initialPosts = ' + JSON.stringify((initialData && initialData.posts) ? initialData.posts : []) + ';';
pageScript += '  var initialTotal = ' + ((initialData && initialData.total) ? initialData.total : 0) + ';';
pageScript += '';
pageScript += '  /* ========== Load Posts ========== */';
pageScript += '  async function loadPosts() {';
pageScript += '    var status = document.getElementById("filterStatus").value;';
pageScript += '    var type = document.getElementById("filterType").value;';
pageScript += '    var keyword = document.getElementById("searchKeyword").value.trim();';
pageScript += '    pageSize = parseInt(document.getElementById("pageSize").value) || 10;';
pageScript += '';
pageScript += '    var url = "/api/admin/posts?page=" + currentPage + "&limit=" + pageSize;';
pageScript += '    if (status !== "") url += "&status=" + status;';
pageScript += '    if (type !== "") url += "&type=" + type;';
pageScript += '    if (keyword) url += "&keyword=" + encodeURIComponent(keyword);';
pageScript += '    if (currentSort) url += "&sortBy=" + currentSort + "&sortDir=" + currentDir;';
pageScript += '';
pageScript += '    var res = await adminFetch(url);';
pageScript += '    if (!res || !res.ok) {';
pageScript += '      var tbody = document.getElementById("postsBody");';
pageScript += '      tbody.innerHTML = \'<tr><td colspan="10"><div class="empty-state"><div class="empty-icon">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div></td></tr>\';';
      pageScript += '      document.getElementById("postCount").textContent = "";';
      pageScript += '      return;';
      pageScript += '    }';
      pageScript += '    var data = await res.json();';
      pageScript += '';
      pageScript += '    if (data.code === 200 && data.data) {';
      pageScript += '      var list = data.data.list || data.data.posts || [];';
      pageScript += '      if (list.length === 0) {';
      pageScript += '        document.getElementById("postsBody").innerHTML = \'<tr><td colspan="10"><div class="empty-state"><div class="empty-icon">&#x1F4ED;</div><p>暂无帖子数据</p></div></td></tr>\';';
      pageScript += '        document.getElementById("postCount").textContent = "共 0 条记录";';
      pageScript += '        document.getElementById("paginationContainer").innerHTML = "";';
      pageScript += '      } else {';
      pageScript += '        renderPosts(list);';
      pageScript += '        var total = data.data.total || 0;';
      pageScript += '        var totalPages = Math.ceil(total / pageSize);';
      pageScript += '        document.getElementById("postCount").textContent = "共 " + total + " 条记录";';
      pageScript += '        renderPagination("paginationContainer", currentPage, totalPages, function(page) {';
      pageScript += '          currentPage = page;';
      pageScript += '          loadPosts();';
      pageScript += '        });';
      pageScript += '      }';
      pageScript += '    } else {';
      pageScript += '      var tbody2 = document.getElementById("postsBody");';
      pageScript += '      tbody2.innerHTML = \'<tr><td colspan="10"><div class="empty-state"><div class="empty-icon">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div></td></tr>\';';
      pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Render Posts ========== */';
pageScript += '  function renderPosts(posts) {';
pageScript += '    var tbody = document.getElementById("postsBody");';
pageScript += '    if (!posts || posts.length === 0) {';
pageScript += '      tbody.innerHTML = \'<tr><td colspan="10"><div class="empty-state"><div class="empty-icon">&#x1F4ED;</div><p>暂无帖子数据</p></div></td></tr>\';';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    var statusMap = { "published": { text: "已发布", cls: "success" }, "draft": { text: "草稿", cls: "warning" }, "hidden": { text: "已隐藏", cls: "default" }, "deleted": { text: "已删除", cls: "danger" }, "default": { text: "未知", cls: "default" } };';
pageScript += '    var typeMap = { "forum": { text: "论坛", cls: "info" }, "wiki": { text: "百科", cls: "success" }, "story": { text: "故事", cls: "warning" }, "default": { text: "其他", cls: "default" } };';
pageScript += '    var catMap = { "cat-feed": "猫狗饲养经验", "cat-disease": "宠物疾病问诊", "food-review": "粮食用品测评", "daily-care": "医疗护理科普", "city-adoption": "无偿宠物领养", "lost-found": "寻宠招领信息", "city-breed": "家养配种交流", "city-walk": "线下遛宠聚会", "daily-show": "毛孩子晒日常", "newcomer": "新人报到灌水", "fun-topic": "养宠吐槽话题", "blacklist": "行业避雷曝光", "secondhand": "宠物用品转让", "pet-transfer": "家养幼犬幼猫", "service": "寄养美容服务", "product-review": "二手好物互换" };';
pageScript += '';
pageScript += '    tbody.innerHTML = posts.map(p => \'<tr>\' +';
pageScript += '      \'<td class="cell-id">\' + (p.id || \'-\') + \'</td>\' +';
pageScript += '      \'<td class="cell-title" title="\' + escapeHtml(p.title || \'\') + \'">\' + escapeHtml(p.title || \'-\') + \'</td>\' +';
pageScript += '      \'<td>\' + escapeHtml(p.username || p.authorName || p.author_username || \'-\') + \'</td>\' +';
pageScript += '      \'<td>\' + statusTag(p.post_type || p.type, typeMap) + \'</td>\' +';
pageScript += '      \'<td style="color:#64748b;">\' + escapeHtml(p.category || \'-\') + \'</td>\' +';
pageScript += '      \'<td>\' + (p.view_count || 0) + \'</td>\' +';
pageScript += '      \'<td>\' + (p.like_count || 0) + \'</td>\' +';
pageScript += '      \'<td>\' + statusTag(p.status, statusMap) + \'</td>\' +';
pageScript += '      \'<td style="font-size:12px;color:#64748b;white-space:nowrap;">\' + formatDate(p.created_at || p.createdAt) + \'</td>\' +';
pageScript += '      \'<td>\' +';
pageScript += '        \'<div style="display:flex;gap:4px;flex-wrap:nowrap;">\' +';
