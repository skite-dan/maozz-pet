<%# dashboard.ejs - 数据看板 %>
<%
var body = '';

body += '<div class="page-header">';
body += '  <h1>数据看板</h1>';
body += '  <p>查看网站运营数据概览</p>';
body += '</div>';

body += '<!-- 统计卡片 -->';
body += '<div class="stats-grid" id="statsGrid">';
body += '  <div class="stat-card">';
body += '    <div class="stat-icon blue">&#x1F465;</div>';
body += '    <div class="stat-info">';
body += '      <div class="stat-value" id="statUsers">-</div>';
body += '      <div class="stat-label">总用户数</div>';
body += '    </div>';
body += '  </div>';
body += '  <div class="stat-card">';
body += '    <div class="stat-icon orange">&#x1F4C4;</div>';
body += '    <div class="stat-info">';
body += '      <div class="stat-value" id="statPosts">-</div>';
body += '      <div class="stat-label">总帖子数</div>';
body += '    </div>';
body += '  </div>';
body += '  <div class="stat-card">';
body += '    <div class="stat-icon green">&#x1F4AC;</div>';
body += '    <div class="stat-info">';
body += '      <div class="stat-value" id="statComments">-</div>';
body += '      <div class="stat-label">总评论数</div>';
body += '    </div>';
body += '  </div>';
body += '  <div class="stat-card">';
body += '    <div class="stat-icon purple">&#x1F4E8;</div>';
body += '    <div class="stat-info">';
body += '      <div class="stat-value" id="statMessages">-</div>';
body += '      <div class="stat-label">总留言数</div>';
body += '    </div>';
body += '  </div>';
body += '  <div class="stat-card">';
body += '    <div class="stat-icon teal">&#x1F441;</div>';
body += '    <div class="stat-info">';
body += '      <div class="stat-value" id="statVisits">-</div>';
body += '      <div class="stat-label">总访问量</div>';
body += '    </div>';
body += '  </div>';
body += '</div>';

body += '<!-- 7天注册趋势图 -->';
body += '<div class="card">';
body += '  <div class="card-header">';
body += '    <h2>&#x1F4C8; 近7天注册趋势</h2>';
body += '    <span style="font-size:12px;color:#94a3b8;">数据来源：用户注册统计</span>';
body += '  </div>';
body += '  <div class="chart-container">';
body += '    <canvas id="trendChart"></canvas>';
body += '  </div>';
body += '</div>';

body += '<!-- 30天访问量趋势 -->';
body += '<div class="card">';
body += '  <div class="card-header">';
body += '    <h2>&#x1F4CA; 近30天访问量趋势</h2>';
body += '    <div style="display:flex;gap:16px;align-items:center;">';
body += '      <span class="visit-legend"><span class="legend-dot pv"></span>PV（页面浏览量）</span>';
body += '      <span class="visit-legend"><span class="legend-dot uv"></span>UV（独立访客）</span>';
body += '    </div>';
body += '  </div>';
body += '  <div class="chart-container" style="height:320px;">';
body += '    <canvas id="visitChart"></canvas>';
body += '  </div>';
body += '</div>';

body += '<!-- 最近帖子 & 最近评论 -->';
body += '<div class="grid-2">';
body += '  <!-- 最近帖子 -->';
body += '  <div class="card">';
body += '    <div class="card-header">';
body += '      <h2>&#x1F4DD; 最近帖子</h2>';
body += '      <a href="/admin/posts" class="btn btn-sm btn-outline">查看全部</a>';
body += '    </div>';
body += '    <div class="table-wrapper">';
body += '      <table class="data-table" id="recentPostsTable">';
body += '        <thead>';
body += '          <tr>';
body += '            <th>ID</th>';
body += '            <th>标题</th>';
body += '            <th>作者</th>';
body += '            <th>类型</th>';
body += '            <th>浏览</th>';
body += '            <th>点赞</th>';
body += '            <th>状态</th>';
body += '            <th>创建时间</th>';
body += '          </tr>';
body += '        </thead>';
body += '        <tbody id="recentPostsBody">';
body += '          <tr><td colspan="8"><div class="loading-spinner"></div></td></tr>';
body += '        </tbody>';
body += '      </table>';
body += '    </div>';
body += '  </div>';
body += '  <!-- 最近评论 -->';
body += '  <div class="card">';
body += '    <div class="card-header">';
body += '      <h2>&#x1F4AC; 最近评论</h2>';
body += '      <a href="/admin/comments" class="btn btn-sm btn-outline">查看全部</a>';
body += '    </div>';
body += '    <div class="table-wrapper">';
body += '      <table class="data-table" id="recentCommentsTable">';
body += '        <thead>';
body += '          <tr>';
body += '            <th>ID</th>';
body += '            <th>内容</th>';
body += '            <th>评论者</th>';
body += '            <th>所属帖子</th>';
body += '            <th>状态</th>';
body += '            <th>创建时间</th>';
body += '          </tr>';
body += '        </thead>';
body += '        <tbody id="recentCommentsBody">';
body += '          <tr><td colspan="6"><div class="loading-spinner"></div></td></tr>';
body += '        </tbody>';
body += '      </table>';
body += '    </div>';
body += '  </div>';
body += '</div>';

var pageScript = '';
pageScript += '<script src="https://cdn.jsdelivr.net/npm/chart.js@4"><\/script>';
pageScript += '<script>';
pageScript += '  let trendChartInstance = null;';
pageScript += '  let visitChartInstance = null;';
pageScript += '';
pageScript += '  /* ========== Load Dashboard Data ========== */';
pageScript += '  async function loadDashboard() {';
pageScript += '    const res = await adminFetch(\'/api/admin/dashboard\');';
pageScript += '    if (!res) return;';
pageScript += '    const data = await res.json();';
pageScript += '';
pageScript += '    if (data.code === 200 && data.data) {';
pageScript += '      renderStats(data.data.stats || {}, data.data.visitStats || {});';
pageScript += '      renderTrendChart(data.data.trend || []);';
pageScript += '      renderVisitChart(data.data.visitStats || {});';
pageScript += '      renderRecentPosts(data.data.recentPosts || []);';
pageScript += '      renderRecentComments(data.data.recentComments || []);';
pageScript += '    } else {';
pageScript += '      showToast(data.message || \'加载数据失败\', \'error\');';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Render Stats ========== */';
pageScript += '  function renderStats(stats, visitStats) {';
pageScript += '    animateNumber(\'statUsers\', stats.totalUsers || 0);';
pageScript += '    animateNumber(\'statPosts\', stats.totalPosts || 0);';
pageScript += '    animateNumber(\'statComments\', stats.totalComments || 0);';
pageScript += '    animateNumber(\'statMessages\', stats.totalMessages || 0);';
pageScript += '    animateNumber(\'statVisits\', visitStats.totalPv || 0);';
pageScript += '  }';
pageScript += '';
pageScript += '  function animateNumber(elementId, target) {';
pageScript += '    var el = document.getElementById(elementId);';
pageScript += '    if (!el) return;';
pageScript += '    var duration = 800;';
pageScript += '    var start = 0;';
pageScript += '    var startTime = performance.now();';
pageScript += '';
pageScript += '    var interval = setInterval(function() {';
pageScript += '      var elapsed = performance.now() - startTime;';
pageScript += '      var progress = Math.min(elapsed / duration, 1);';
pageScript += '      var eased = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);';
pageScript += '      var current = Math.floor(start + (target - start) * eased);';
pageScript += '      el.textContent = current.toLocaleString();';
pageScript += '      if (progress >= 1) {';
pageScript += '        clearInterval(interval);';
pageScript += '      }';
pageScript += '    }, 16);';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Render Trend Chart ========== */';
pageScript += '  function renderTrendChart(trend) {';
pageScript += '    const ctx = document.getElementById(\'trendChart\');';
pageScript += '    if (!ctx) return;';
pageScript += '';
pageScript += '    const labels = trend.map(item => {';
pageScript += '      const d = new Date(item.date);';
pageScript += '      return (d.getMonth() + 1) + \'/\' + d.getDate();';
pageScript += '    });';
pageScript += '    const values = trend.map(item => item.count || 0);';
pageScript += '';
pageScript += '    if (trendChartInstance) {';
pageScript += '      trendChartInstance.destroy();';
pageScript += '    }';
pageScript += '';
pageScript += '    trendChartInstance = new Chart(ctx, {';
pageScript += '      type: \'bar\',';
pageScript += '      data: {';
pageScript += '        labels: labels,';
pageScript += '        datasets: [';
pageScript += '          {';
pageScript += '            label: \'注册人数\',';
pageScript += '            data: values,';
pageScript += '            backgroundColor: \'rgba(255, 107, 53, 0.2)\',';
pageScript += '            borderColor: \'#ff6b35\',';
pageScript += '            borderWidth: 2,';
pageScript += '            borderRadius: 8,';
pageScript += '            borderSkipped: false,';
pageScript += '            barThickness: 32,';
pageScript += '            order: 2';
pageScript += '          },';
pageScript += '          {';
pageScript += '            label: \'趋势线\',';
pageScript += '            data: values,';
pageScript += '            type: \'line\',';
pageScript += '            borderColor: \'#ff6b35\',';
pageScript += '            backgroundColor: \'transparent\',';
pageScript += '            borderWidth: 2.5,';
pageScript += '            pointBackgroundColor: \'#ff6b35\',';
pageScript += '            pointBorderColor: \'#fff\',';
pageScript += '            pointBorderWidth: 2,';
pageScript += '            pointRadius: 5,';
pageScript += '            pointHoverRadius: 7,';
pageScript += '            tension: 0.4,';
pageScript += '            fill: false,';
pageScript += '            order: 1';
pageScript += '          }';
pageScript += '        ]';
pageScript += '      },';
pageScript += '      options: {';
pageScript += '        responsive: true,';
pageScript += '        maintainAspectRatio: false,';
pageScript += '        interaction: { intersect: false, mode: \'index\' },';
pageScript += '        plugins: {';
pageScript += '          legend: {';
pageScript += '            display: true, position: \'top\', align: \'end\',';
pageScript += '            labels: { usePointStyle: true, pointStyle: \'circle\', padding: 16, font: { size: 12, family: \'-apple-system, sans-serif\' }, color: \'#64748b\', filter: function(item) { return item.text === \'注册人数\'; } }';
pageScript += '          },';
pageScript += '          tooltip: {';
pageScript += '            backgroundColor: \'#1e293b\', titleFont: { size: 13 }, bodyFont: { size: 12 }, padding: 12, cornerRadius: 8, displayColors: false,';
pageScript += '            callbacks: { title: function(items) { return items[0].label; }, label: function(item) { return \'新增注册：\' + item.raw + \' 人\'; } }';
pageScript += '          }';
pageScript += '        },';
pageScript += '        scales: {';
pageScript += '          x: { grid: { display: false }, ticks: { color: \'#64748b\', font: { size: 12 } } },';
pageScript += '          y: { beginAtZero: true, grid: { color: \'#f1f5f9\', drawBorder: false }, ticks: { color: \'#64748b\', font: { size: 12 }, stepSize: 1, callback: function(value) { return Number.isInteger(value) ? value : \'\'; } } }';
pageScript += '        }';
pageScript += '      }';
pageScript += '    });';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Render Visit Chart ========== */';
pageScript += '  function renderVisitChart(visitStats) {';
pageScript += '    var ctx = document.getElementById(\'visitChart\');';
pageScript += '    if (!ctx) return;';
pageScript += '    var trend = visitStats.trend || [];';
pageScript += '    if (trend.length === 0) {';
pageScript += '      ctx.parentElement.innerHTML = \'<div class="empty-state"><div class="empty-icon">&#x1F4CA;</div><p>暂无访问数据，前台访问后将自动记录</p></div>\';';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    var labels = trend.map(function(item) {';
pageScript += '      var d = new Date(item.date);';
pageScript += '      return (d.getMonth() + 1) + \'/\' + d.getDate();';
pageScript += '    });';
pageScript += '    var pvData = trend.map(function(item) { return item.pv || 0; });';
pageScript += '    var uvData = trend.map(function(item) { return item.uv || 0; });';
pageScript += '';
pageScript += '    if (visitChartInstance) visitChartInstance.destroy();';
pageScript += '';
pageScript += '    visitChartInstance = new Chart(ctx, {';
pageScript += '      type: \'line\',';
pageScript += '      data: {';
pageScript += '        labels: labels,';
pageScript += '        datasets: [';
pageScript += '          {';
pageScript += '            label: \'PV（页面浏览量）\',';
pageScript += '            data: pvData,';
pageScript += '            borderColor: \'#3b82f6\',';
pageScript += '            backgroundColor: \'rgba(59, 130, 246, 0.08)\',';
pageScript += '            borderWidth: 2.5,';
pageScript += '            pointBackgroundColor: \'#3b82f6\',';
pageScript += '            pointBorderColor: \'#fff\',';
pageScript += '            pointBorderWidth: 2,';
pageScript += '            pointRadius: 3,';
pageScript += '            pointHoverRadius: 6,';
pageScript += '            tension: 0.4,';
pageScript += '            fill: true,';
pageScript += '            order: 2';
pageScript += '          },';
pageScript += '          {';
pageScript += '            label: \'UV（独立访客）\',';
pageScript += '            data: uvData,';
pageScript += '            borderColor: \'#22c55e\',';
pageScript += '            backgroundColor: \'rgba(34, 197, 94, 0.08)\',';
pageScript += '            borderWidth: 2.5,';
pageScript += '            pointBackgroundColor: \'#22c55e\',';
pageScript += '            pointBorderColor: \'#fff\',';
pageScript += '            pointBorderWidth: 2,';
pageScript += '            pointRadius: 3,';
pageScript += '            pointHoverRadius: 6,';
pageScript += '            tension: 0.4,';
pageScript += '            fill: true,';
pageScript += '            order: 1';
pageScript += '          }';
pageScript += '        ]';
pageScript += '      },';
pageScript += '      options: {';
pageScript += '        responsive: true,';
pageScript += '        maintainAspectRatio: false,';
pageScript += '        interaction: { intersect: false, mode: \'index\' },';
pageScript += '        plugins: {';
pageScript += '          legend: { display: false },';
pageScript += '          tooltip: {';
pageScript += '            backgroundColor: \'#1e293b\', titleFont: { size: 13 }, bodyFont: { size: 12 }, padding: 12, cornerRadius: 8,';
pageScript += '            callbacks: {';
pageScript += '              label: function(item) {';
pageScript += '                return item.dataset.label + \'：\' + item.raw.toLocaleString();';
pageScript += '              }';
pageScript += '            }';
pageScript += '          }';
pageScript += '        },';
pageScript += '        scales: {';
pageScript += '          x: { grid: { display: false }, ticks: { color: \'#64748b\', font: { size: 11 }, maxRotation: 45, autoSkip: true, maxTicksLimit: 15 } },';
pageScript += '          y: { beginAtZero: true, grid: { color: \'#f1f5f9\', drawBorder: false }, ticks: { color: \'#64748b\', font: { size: 11 } } }';
pageScript += '        }';
pageScript += '      }';
pageScript += '    });';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Render Recent Posts ========== */';
pageScript += '  function renderRecentPosts(posts) {';
pageScript += '    const tbody = document.getElementById(\'recentPostsBody\');';
pageScript += '    if (!tbody) return;';
pageScript += '';
pageScript += '    if (!posts || posts.length === 0) {';
pageScript += '      tbody.innerHTML = \'<tr><td colspan="8"><div class="empty-state"><div class="empty-icon">&#x1F4ED;</div><p>暂无帖子数据</p></div></td></tr>\';';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    const statusMap = { \'1\': { text: \'正常\', cls: \'success\' }, \'0\': { text: \'待审核\', cls: \'warning\' }, \'2\': { text: \'已隐藏\', cls: \'default\' }, \'3\': { text: \'已删除\', cls: \'danger\' } };';
pageScript += '    const typeMap = { \'forum\': \'论坛\', \'wiki\': \'百科\', \'story\': \'故事\' };';
pageScript += '';
pageScript += '    tbody.innerHTML = posts.map(post => \'<tr>\' +';
pageScript += '      \'<td class="cell-id">\' + (post.id || \'-\') + \'</td>\' +';
pageScript += '      \'<td class="cell-title" title="\' + escapeHtml(post.title || \'\') + \'">\' + escapeHtml(post.title || \'-\') + \'</td>\' +';
pageScript += '      \'<td>\' + escapeHtml(post.authorName || post.author_username || \'-\') + \'</td>\' +';
pageScript += '      \'<td><span class="status-tag info">\' + (typeMap[post.type] || post.type || \'-\') + \'</span></td>\' +';
pageScript += '      \'<td>\' + (post.view_count || 0) + \'</td>\' +';
pageScript += '      \'<td>\' + (post.like_count || 0) + \'</td>\' +';
pageScript += '      \'<td>\' + statusTag(post.status, statusMap) + \'</td>\' +';
pageScript += '      \'<td style="white-space:nowrap;font-size:12px;color:#64748b;">\' + formatDateShort(post.created_at || post.createdAt) + \'</td>\' +';
pageScript += '      \'</tr>\').join(\'\');';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Render Recent Comments ========== */';
pageScript += '  function renderRecentComments(comments) {';
pageScript += '    const tbody = document.getElementById(\'recentCommentsBody\');';
pageScript += '    if (!tbody) return;';
pageScript += '';
pageScript += '    if (!comments || comments.length === 0) {';
pageScript += '      tbody.innerHTML = \'<tr><td colspan="6"><div class="empty-state"><div class="empty-icon">&#x1F4ED;</div><p>暂无评论数据</p></div></td></tr>\';';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    const statusMap = { \'1\': { text: \'正常\', cls: \'success\' }, \'0\': { text: \'待审核\', cls: \'warning\' }, \'2\': { text: \'已隐藏\', cls: \'default\' }, \'3\': { text: \'已删除\', cls: \'danger\' } };';
pageScript += '';
pageScript += '    tbody.innerHTML = comments.map(c => \'<tr>\' +';
pageScript += '      \'<td class="cell-id">\' + (c.id || \'-\') + \'</td>\' +';
pageScript += '      \'<td class="cell-content" title="\' + escapeHtml(c.content || \'\') + \'">\' + escapeHtml(truncate(c.content || \'-\', 30)) + \'</td>\' +';
pageScript += '      \'<td>\' + escapeHtml(c.username || c.authorName || \'-\') + \'</td>\' +';
pageScript += '      \'<td class="cell-content" title="\' + escapeHtml(c.postTitle || \'\') + \'">\' + escapeHtml(truncate(c.postTitle || \'-\', 15)) + \'</td>\' +';
pageScript += '      \'<td>\' + statusTag(c.status, statusMap) + \'</td>\' +';
pageScript += '      \'<td style="white-space:nowrap;font-size:12px;color:#64748b;">\' + formatDateShort(c.created_at || c.createdAt) + \'</td>\' +';
pageScript += '      \'</tr>\').join(\'\');';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Escape HTML ========== */';
pageScript += '  function escapeHtml(str) {';
pageScript += '    if (!str) return \'\';';
pageScript += '    const div = document.createElement(\'div\');';
pageScript += '    div.textContent = str;';
pageScript += '    return div.innerHTML;';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Init ========== */';
pageScript += '  document.addEventListener(\'DOMContentLoaded\', loadDashboard);';
pageScript += '<\/script>';
%>
<%- include('layout', { pageTitle: '数据看板', activeMenu: 'dashboard', body: body, pageScript: pageScript }) %>
