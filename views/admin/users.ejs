<%# users.ejs - 用户管理 %>
<%
var body = '';

body += '<div class="page-header">';
body += '  <h1>用户管理</h1>';
body += '  <p>管理平台注册用户，查看用户信息与状态</p>';
body += '</div>';

body += '<!-- 筛选栏 -->';
body += '<div class="filter-bar">';
body += '  <select id="filterStatus" onchange="handleFilter()">';
body += '    <option value="">全部状态</option>';
body += '    <option value="1">正常</option>';
body += '    <option value="0">已禁用</option>';
body += '  </select>';
body += '  <select id="filterRole" onchange="handleFilter()">';
body += '    <option value="">全部角色</option>';
body += '    <option value="user">普通用户</option>';
body += '    <option value="admin">管理员</option>';
body += '  </select>';
body += '  <div class="search-input">';
body += '    <input type="text" id="searchKeyword" placeholder="搜索用户名/邮箱..." onkeydown="if(event.key===\'Enter\')handleFilter()">';
body += '  </div>';
body += '  <select id="pageSize" onchange="handlePageSizeChange()">';
body += '    <option value="10">10条/页</option>';
body += '    <option value="30">30条/页</option>';
body += '    <option value="50">50条/页</option>';
body += '  </select>';
body += '  <button class="btn btn-primary" onclick="handleFilter()">&#x1F50D; 搜索</button>';
body += '  <button class="btn btn-outline" onclick="resetFilter()">&#x21BA; 重置</button>';
body += '</div>';

body += '<!-- 用户表格 -->';
body += '<div class="card">';
body += '  <div class="card-header">';
body += '    <h2>用户列表</h2>';
body += '    <span id="userCount" style="font-size:13px;color:#94a3b8;"></span>';
body += '  </div>';
body += '  <div class="table-wrapper">';
body += '    <table class="data-table" id="usersTable">';
body += '      <thead>';
body += '        <tr>';
body += '          <th data-sort="id">ID <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="username">用户名 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th>邮箱</th>';
body += '          <th>头像</th>';
body += '          <th data-sort="role">角色 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="status">状态 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th data-sort="post_count">帖子数 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th>最后登录</th>';
body += '          <th data-sort="created_at">注册时间 <span class="sort-icon">&#x25B4;&#x25BE;</span></th>';
body += '          <th>操作</th>';
body += '        </tr>';
body += '      </thead>';
body += '      <tbody id="usersBody">';
body += '        <tr><td colspan="10"><div class="loading-spinner"></div></td></tr>';
body += '      </tbody>';
body += '    </table>';
body += '  </div>';
body += '  <div id="paginationContainer"></div>';
body += '</div>';

var pageScript = '';
pageScript += '<script>';
pageScript += '  let currentPage = 1;';
pageScript += '  let pageSize = 10;';
pageScript += '  let currentSort = \'\';';
pageScript += '  let currentDir = \'\';';
pageScript += '  var initialUsers = ' + JSON.stringify((initialData && initialData.users) ? initialData.users : []) + ';';
pageScript += '  var initialTotal = ' + ((initialData && initialData.total) ? initialData.total : 0) + ';';
pageScript += '';
pageScript += '  /* ========== Load Users ========== */';
pageScript += '  async function loadUsers() {';
pageScript += '    const status = document.getElementById(\'filterStatus\').value;';
pageScript += '    const role = document.getElementById(\'filterRole\').value;';
pageScript += '    const keyword = document.getElementById(\'searchKeyword\').value.trim();';
pageScript += '    pageSize = parseInt(document.getElementById(\'pageSize\').value) || 10;';
pageScript += '';
pageScript += '    let url = \'/api/admin/users?page=\' + currentPage + \'&limit=\' + pageSize;';
pageScript += '    if (status !== \'\') url += \'&status=\' + status;';
pageScript += '    if (role !== \'\') url += \'&role=\' + role;';
pageScript += '    if (keyword) url += \'&keyword=\' + encodeURIComponent(keyword);';
pageScript += '    if (currentSort) url += \'&sortBy=\' + currentSort + \'&sortDir=\' + currentDir;';
pageScript += '';
pageScript += '    const res = await adminFetch(url);';
pageScript += '    if (!res || !res.ok) {';
pageScript += '      var tbody = document.getElementById("usersBody");';
pageScript += '      tbody.innerHTML = "<tr><td colspan=\\"10\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div></td></tr>";';
pageScript += '      document.getElementById("userCount").textContent = "";';
pageScript += '      return;';
pageScript += '    }';
pageScript += '    const data = await res.json();';
pageScript += '';
pageScript += '    if (data.code === 200 && data.data) {';
pageScript += '      var list = data.data.list || data.data.users || [];';
pageScript += '      if (list.length === 0) {';
pageScript += '        document.getElementById("usersBody").innerHTML = "<tr><td colspan=\\"10\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x1F4ED;</div><p>暂无用户数据</p></div></td></tr>";';
pageScript += '        document.getElementById("userCount").textContent = "共 0 条记录";';
pageScript += '        document.getElementById("paginationContainer").innerHTML = "";';
pageScript += '      } else {';
pageScript += '        renderUsers(list);';
pageScript += '        const total = data.data.total || 0;';
pageScript += '        const totalPages = Math.ceil(total / pageSize);';
pageScript += '        document.getElementById("userCount").textContent = "共 " + total + " 条记录";';
pageScript += '        renderPagination("paginationContainer", currentPage, totalPages, function(page) {';
pageScript += '          currentPage = page;';
pageScript += '          loadUsers();';
pageScript += '        });';
pageScript += '      }';
pageScript += '    } else {';
pageScript += '      var tbody2 = document.getElementById("usersBody");';
pageScript += '      tbody2.innerHTML = "<tr><td colspan=\\"10\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x26A0;</div><p>请求失败，请刷新页面重试</p></div></td></tr>";';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Render Users ========== */';
pageScript += '  function renderUsers(users) {';
pageScript += '    const tbody = document.getElementById(\'usersBody\');';
pageScript += '    if (!users || users.length === 0) {';
pageScript += '      tbody.innerHTML = \'<tr><td colspan="10"><div class="empty-state"><div class="empty-icon">&#x1F4ED;</div><p>暂无用户数据</p></div></td></tr>\';';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    const statusMap = { \'1\': { text: \'正常\', cls: \'success\' }, \'0\': { text: \'已禁用\', cls: \'danger\' } };';
pageScript += '    const roleMap = { \'admin\': { text: \'管理员\', cls: \'warning\' }, \'user\': { text: \'普通用户\', cls: \'info\' } };';
pageScript += '';
pageScript += '    tbody.innerHTML = users.map(u => \'<tr>\' +';
pageScript += '      \'<td class="cell-id">\' + (u.id || \'-\') + \'</td>\' +';
pageScript += '      \'<td><strong>\' + escapeHtml(u.username || \'-\') + \'</strong></td>\' +';
pageScript += '      \'<td style="color:#64748b;">\' + escapeHtml(u.email || \'-\') + \'</td>\' +';
pageScript += '      \'<td>\' + (u.avatar';
pageScript += '        ? \'<img class="cell-avatar" src="\' + escapeHtml(u.avatar) + \'" alt="avatar" onerror="this.src=\\\'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22><rect fill=%22%23e2e8f0%22 width=%2232%22 height=%2232%22 rx=%2216%22/><text x=%2216%22 y=%2220%22 text-anchor=%22middle%22 font-size=%2214%22>&#x1F464;</text></svg>\\\'">\'';
pageScript += '        : \'<span style="font-size:24px;">&#x1F464;</span>\'';
pageScript += '      ) + \'</td>\' +';
pageScript += '      \'<td>\' + statusTag(u.role, roleMap) + \'</td>\' +';
pageScript += '      \'<td>\' + statusTag(u.status, statusMap) + \'</td>\' +';
pageScript += '      \'<td>\' + (u.post_count || 0) + \'</td>\' +';
pageScript += '      \'<td style="font-size:12px;color:#64748b;white-space:nowrap;">\' + formatDate(u.last_login_at || u.lastLoginAt) + \'</td>\' +';
pageScript += '      \'<td style="font-size:12px;color:#64748b;white-space:nowrap;">\' + formatDate(u.created_at || u.createdAt) + \'</td>\' +';
pageScript += '      \'<td>\' +';
pageScript += '        \'<button class="btn btn-sm \' + (u.status === 1 ? \'btn-warning\' : \'btn-success\') + \'"\' +';
pageScript += '        \' onclick="toggleUserStatus(\' + u.id + \', \' + u.status + \')">\' +';
pageScript += '        (u.status === 1 ? \'&#x1F6AB; 禁用\' : \'&#x2705; 启用\') +';
pageScript += '        \'</button>\' +';
pageScript += '      \'</td>\' +';
pageScript += '      \'</tr>\').join(\'\');';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Toggle User Status ========== */';
pageScript += '  async function toggleUserStatus(userId, currentStatus) {';
pageScript += '    const newStatus = currentStatus === 1 ? 0 : 1;';
pageScript += '    const action = newStatus === 0 ? \'禁用\' : \'启用\';';
pageScript += '';
pageScript += '    showConfirm(';
pageScript += '      action + \'用户\',';
pageScript += '      \'确定要\' + action + \'该用户吗？\' + (newStatus === 0 ? \'禁用后用户将无法登录。\' : \'\'),';
pageScript += '      async function() {';
pageScript += '        const res = await adminFetch(\'/api/admin/users/\' + userId + \'/status\', {';
pageScript += '          method: \'PUT\',';
pageScript += '          body: JSON.stringify({ status: newStatus })';
pageScript += '        });';
pageScript += '        if (!res) return;';
pageScript += '        const data = await res.json();';
pageScript += '        if (data.code === 200) {';
pageScript += '          showToast(\'用户已\' + action, \'success\');';
pageScript += '          loadUsers();';
pageScript += '        } else {';
pageScript += '          showToast(data.message || \'操作失败\', \'error\');';
pageScript += '        }';
pageScript += '      }';
pageScript += '    );';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Filter ========== */';
pageScript += '  function handleFilter() {';
pageScript += '    currentPage = 1;';
pageScript += '    loadUsers();';
pageScript += '  }';
pageScript += '';
pageScript += '  function resetFilter() {';
pageScript += '    document.getElementById(\'filterStatus\').value = \'\';';
pageScript += '    document.getElementById(\'filterRole\').value = \'\';';
pageScript += '    document.getElementById(\'searchKeyword\').value = \'\';';
pageScript += '    document.getElementById(\'pageSize\').value = \'10\';';
pageScript += '    currentPage = 1;';
pageScript += '    pageSize = 10;';
pageScript += '    currentSort = \'\';';
pageScript += '    currentDir = \'\';';
pageScript += '    loadUsers();';
pageScript += '  }';
pageScript += '';
pageScript += '  function handlePageSizeChange() {';
pageScript += '    currentPage = 1;';
pageScript += '    pageSize = parseInt(document.getElementById(\'pageSize\').value) || 10;';
pageScript += '    loadUsers();';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Escape HTML ========== */';
pageScript += '  function escapeHtml(str) {';
pageScript += '    if (!str) return \'\';';
pageScript += '    const div = document.createElement(\'div\');';
pageScript += '    div.textContent = str;';
pageScript += '    return div.innerHTML;';
pageScript += '  }';
pageScript += '';
pageScript += '  /* ========== Init ========== */';
pageScript += '  document.addEventListener(\'DOMContentLoaded\', function() {';
pageScript += '    if (initialUsers && initialUsers.length > 0) {';
pageScript += '      renderUsers(initialUsers);';
pageScript += '      document.getElementById("userCount").textContent = "共 " + initialTotal + " 条记录";';
pageScript += '      var totalPages = Math.ceil(initialTotal / pageSize);';
pageScript += '      renderPagination("paginationContainer", 1, totalPages, function(page) {';
pageScript += '        currentPage = page;';
pageScript += '        loadUsers();';
pageScript += '      });';
pageScript += '    } else {';
pageScript += '      document.getElementById("usersBody").innerHTML = "<tr><td colspan=\\"10\\"><div class=\\"empty-state\\"><div class=\\"empty-icon\\">&#x1F4ED;</div><p>暂无用户数据</p></div></td></tr>";';
pageScript += '      document.getElementById("userCount").textContent = "共 0 条记录";';
pageScript += '    }';
pageScript += '    initTableSort(document.getElementById(\'usersTable\'), function(field, dir) {';
pageScript += '      currentSort = field;';
pageScript += '      currentDir = dir;';
pageScript += '      currentPage = 1;';
pageScript += '      loadUsers();';
pageScript += '    });';
pageScript += '  });';
pageScript += '<\/script>';
%>
<%- include('layout', { pageTitle: '用户管理', activeMenu: 'users', body: body, pageScript: pageScript }) %>
