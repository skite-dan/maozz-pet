<%# banners.ejs - 轮播图管理 %>
<%
var body = '';

body += '<div class="page-header">';
body += '  <h1>轮播图管理</h1>';
body += '  <p>管理首页轮播图，最多支持5张图片</p>';
body += '</div>';

body += '<div class="card">';
body += '  <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">';
body += '    <h2>轮播图列表</h2>';
body += '    <button class="btn btn-primary" onclick="openBannerModal()">+ 添加轮播图</button>';
body += '  </div>';
body += '  <div class="table-wrapper">';
body += '    <table class="data-table" id="bannersTable">';
body += '      <thead>';
body += '        <tr>';
body += '          <th>ID</th>';
body += '          <th>图片预览</th>';
body += '          <th>标题</th>';
body += '          <th>链接</th>';
body += '          <th>排序</th>';
body += '          <th>状态</th>';
body += '          <th>操作</th>';
body += '        </tr>';
body += '      </thead>';
body += '      <tbody id="bannersBody">';
body += '        <tr><td colspan="7"><div class="loading-spinner"></div></td></tr>';
body += '      </tbody>';
body += '    </table>';
body += '  </div>';
body += '</div>';

// 添加/编辑弹窗
body += '<div class="modal" id="bannerModal">';
body += '  <div class="modal-overlay" onclick="closeBannerModal()"></div>';
body += '  <div class="modal-content" style="max-width:560px;">';
body += '    <div class="modal-header">';
body += '      <h3 id="bannerModalTitle">添加轮播图</h3>';
body += '      <button class="modal-close" onclick="closeBannerModal()">&times;</button>';
body += '    </div>';
body += '    <div class="modal-body">';
body += '      <input type="hidden" id="bannerId">';
body += '      <div class="form-group">';
body += '        <label class="form-label">标题</label>';
body += '        <input type="text" class="form-input" id="bannerTitle" placeholder="轮播图标题">';
body += '      </div>';
body += '      <div class="form-group">';
body += '        <label class="form-label">上传图片 <span style="color:#ef4444;">*</span></label>';
body += '        <div class="upload-area" id="bannerUploadArea" onclick="document.getElementById(\'bannerImageInput\').click()">';
body += '          <div class="upload-icon">&#x1F4F7;</div>';
body += '          <p>点击上传轮播图（支持JPG/PNG）</p>';
body += '        </div>';
body += '        <input type="file" id="bannerImageInput" accept="image/*" style="display:none;" onchange="handleBannerImageUpload(this)">';
body += '        <div class="upload-preview" id="bannerImagePreview"></div>';
body += '      </div>';
body += '      <div class="form-group">';
body += '        <label class="form-label">图片地址 <span style="color:#ef4444;">*</span></label>';
body += '        <input type="text" class="form-input" id="bannerImageUrl" placeholder="上传后自动填充，或手动输入图片URL">';
body += '      </div>';
body += '      <div class="form-group">';
body += '        <label class="form-label">链接地址</label>';
body += '        <input type="text" class="form-input" id="bannerLinkUrl" placeholder="https://example.com 或 /post/1">';
body += '      </div>';
body += '      <div class="form-group">';
body += '        <label class="form-label">排序</label>';
body += '        <input type="number" class="form-input" id="bannerSortOrder" value="0" min="0">';
body += '      </div>';
body += '      <div class="form-group">';
body += '        <label class="form-label">状态</label>';
body += '        <select class="form-input" id="bannerStatus">';
body += '          <option value="1">启用</option>';
body += '          <option value="0">禁用</option>';
body += '        </select>';
body += '      </div>';
body += '      <div class="form-error" id="bannerError"></div>';
body += '    </div>';
body += '    <div class="modal-footer">';
body += '      <button class="btn btn-outline" onclick="closeBannerModal()">取消</button>';
body += '      <button class="btn btn-primary" onclick="saveBanner()">保存</button>';
body += '    </div>';
body += '  </div>';
body += '</div>';

var pageScript = '';
pageScript += '<script>';
pageScript += '  let banners = [];';
pageScript += '  let currentBannerId = null;';
pageScript += '';
pageScript += '  async function loadBanners() {';
pageScript += '    const res = await adminFetch("/api/admin/banners");';
pageScript += '    if (!res) return;';
pageScript += '    const data = await res.json();';
pageScript += '    if (data.code === 200) {';
pageScript += '      banners = data.data || [];';
pageScript += '      renderBanners();';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  function renderBanners() {';
pageScript += '    const tbody = document.getElementById("bannersBody");';
pageScript += '    if (banners.length === 0) {';
pageScript += '      tbody.innerHTML = \'<tr><td colspan="7" style="text-align:center;padding:40px;color:#94a3b8;">暂无轮播图</td></tr>\';';
pageScript += '      return;';
pageScript += '    }';
pageScript += '    tbody.innerHTML = banners.map(b => {';
pageScript += '      const statusBadge = b.status === 1';
pageScript += '        ? \'<span class="badge success">启用</span>\'';
pageScript += '        : \'<span class="badge danger">禁用</span>\';';
pageScript += '      return \'<tr>\' +';
pageScript += '        \'<td>\' + b.id + \'</td>\' +';
pageScript += '        \'<td><img src="\' + b.image_url + \'" style="width:120px;height:60px;object-fit:cover;border-radius:6px;" onerror="this.src=\\\'/images/default-banner.png\\\'"></td>\' +';
pageScript += '        \'<td>\' + (b.title || "-") + \'</td>\' +';
pageScript += '        \'<td>\' + (b.link_url ? \'<a href="\' + b.link_url + \'" target="_blank">\' + b.link_url + \'</a>\' : "-") + \'</td>\' +';
pageScript += '        \'<td>\' + b.sort_order + \'</td>\' +';
pageScript += '        \'<td>\' + statusBadge + \'</td>\' +';
pageScript += '        \'<td>\' +';
pageScript += '          \'<button class="btn btn-sm btn-outline" onclick="editBanner(\' + b.id + \')">编辑</button> \' +';
pageScript += '          \'<button class="btn btn-sm btn-danger" onclick="deleteBanner(\' + b.id + \')">删除</button>\' +';
pageScript += '        \'</td>\' +';
pageScript += '      \'</tr>\';';
pageScript += '    }).join("");';
pageScript += '  }';
pageScript += '';
pageScript += '  function openBannerModal() {';
pageScript += '    currentBannerId = null;';
pageScript += '    document.getElementById("bannerModalTitle").textContent = "添加轮播图";';
pageScript += '    document.getElementById("bannerId").value = "";';
pageScript += '    document.getElementById("bannerTitle").value = "";';
pageScript += '    document.getElementById("bannerImageUrl").value = "";';
pageScript += '    document.getElementById("bannerLinkUrl").value = "";';
pageScript += '    document.getElementById("bannerSortOrder").value = "0";';
pageScript += '    document.getElementById("bannerStatus").value = "1";';
pageScript += '    document.getElementById("bannerError").style.display = "none";';
pageScript += '    document.getElementById("bannerImagePreview").innerHTML = "";';
pageScript += '    document.getElementById("bannerModal").classList.add("active");';
pageScript += '    document.body.style.overflow = "hidden";';
pageScript += '  }';
pageScript += '';
pageScript += '  function closeBannerModal() {';
pageScript += '    document.getElementById("bannerModal").classList.remove("active");';
pageScript += '    document.body.style.overflow = "";';
pageScript += '  }';
pageScript += '';
pageScript += '  function editBanner(id) {';
pageScript += '    const b = banners.find(x => x.id === id);';
pageScript += '    if (!b) return;';
pageScript += '    currentBannerId = id;';
pageScript += '    document.getElementById("bannerModalTitle").textContent = "编辑轮播图";';
pageScript += '    document.getElementById("bannerId").value = b.id;';
pageScript += '    document.getElementById("bannerTitle").value = b.title || "";';
pageScript += '    document.getElementById("bannerImageUrl").value = b.image_url || "";';
pageScript += '    document.getElementById("bannerLinkUrl").value = b.link_url || "";';
pageScript += '    document.getElementById("bannerSortOrder").value = b.sort_order || 0;';
pageScript += '    document.getElementById("bannerStatus").value = b.status;';
pageScript += '    document.getElementById("bannerError").style.display = "none";';
pageScript += '    const preview = document.getElementById("bannerImagePreview");';
pageScript += '    if (b.image_url) {';
pageScript += '      preview.innerHTML = \'<div class="preview-item"><img src="\' + b.image_url + \'" alt=""></div>\';';
pageScript += '    } else {';
pageScript += '      preview.innerHTML = "";';
pageScript += '    }';
pageScript += '    document.getElementById("bannerModal").classList.add("active");';
pageScript += '    document.body.style.overflow = "hidden";';
pageScript += '  }';
pageScript += '';
pageScript += '  async function handleBannerImageUpload(input) {';
pageScript += '    const file = input.files[0];';
pageScript += '    if (!file) return;';
pageScript += '    const formData = new FormData();';
pageScript += '    formData.append("images", file);';
pageScript += '    try {';
pageScript += '      const res = await adminFetch("/api/upload/images", { method: "POST", body: formData });';
pageScript += '      if (!res || !res.ok) throw new Error("上传失败");';
pageScript += '      const data = await res.json();';
pageScript += '      if (data.code === 200 && data.data && data.data.length > 0) {';
pageScript += '        const url = data.data[0].url;';
pageScript += '        document.getElementById("bannerImageUrl").value = url;';
pageScript += '        document.getElementById("bannerImagePreview").innerHTML = \'<div class="preview-item"><img src="\' + url + \'" alt=""></div>\';';
pageScript += '        showToast("图片上传成功", "success");';
pageScript += '      } else {';
pageScript += '        showToast(data.message || "上传失败", "error");';
pageScript += '      }';
pageScript += '    } catch (err) {';
pageScript += '      showToast("图片上传失败: " + (err.message || ""), "error");';
pageScript += '    }';
pageScript += '    input.value = "";';
pageScript += '  }';
pageScript += '';
pageScript += '  async function saveBanner() {';
pageScript += '    const title = document.getElementById("bannerTitle").value.trim();';
pageScript += '    const imageUrl = document.getElementById("bannerImageUrl").value.trim();';
pageScript += '    const linkUrl = document.getElementById("bannerLinkUrl").value.trim();';
pageScript += '    const sortOrder = parseInt(document.getElementById("bannerSortOrder").value) || 0;';
pageScript += '    const status = parseInt(document.getElementById("bannerStatus").value);';
pageScript += '    const errorEl = document.getElementById("bannerError");';
pageScript += '';
pageScript += '    if (!imageUrl) {';
pageScript += '      errorEl.textContent = "图片地址不能为空";';
pageScript += '      errorEl.style.display = "block";';
pageScript += '      return;';
pageScript += '    }';
pageScript += '';
pageScript += '    const payload = { title, image_url: imageUrl, link_url: linkUrl, sort_order: sortOrder, status };';
pageScript += '    const url = currentBannerId ? "/api/admin/banners/" + currentBannerId : "/api/admin/banners";';
pageScript += '    const method = currentBannerId ? "PUT" : "POST";';
pageScript += '';
pageScript += '    try {';
pageScript += '      const res = await adminFetch(url, { method, headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });';
pageScript += '      const data = await res.json();';
pageScript += '      if (data.code === 200) {';
pageScript += '        closeBannerModal();';
pageScript += '        showToast(currentBannerId ? "更新成功" : "添加成功", "success");';
pageScript += '        loadBanners();';
pageScript += '      } else {';
pageScript += '        errorEl.textContent = data.message || "操作失败";';
pageScript += '        errorEl.style.display = "block";';
pageScript += '      }';
pageScript += '    } catch (err) {';
pageScript += '      errorEl.textContent = "网络错误";';
pageScript += '      errorEl.style.display = "block";';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  async function deleteBanner(id) {';
pageScript += '    if (!confirm("确定要删除这张轮播图吗？")) return;';
pageScript += '    try {';
pageScript += '      const res = await adminFetch("/api/admin/banners/" + id, { method: "DELETE" });';
pageScript += '      const data = await res.json();';
pageScript += '      if (data.code === 200) {';
pageScript += '        showToast("删除成功", "success");';
pageScript += '        loadBanners();';
pageScript += '      } else {';
pageScript += '        showToast(data.message || "删除失败", "error");';
pageScript += '      }';
pageScript += '    } catch (err) {';
pageScript += '      showToast("网络错误", "error");';
pageScript += '    }';
pageScript += '  }';
pageScript += '';
pageScript += '  loadBanners();';
pageScript += '</script>';
%>

<%- include('layout', { pageTitle: '轮播图管理', activeMenu: 'banners', body: body, pageScript: pageScript }) %>
