<%
  var body = '';
  body += '<div class="breadcrumb">';
  body += '  <a href="/">首页</a> <span class="sep">/</span>';
  body += '  <span class="current">我的毛孩子</span>';
  body += '</div>';

  body += '<div class="page-layout">';
  body += '  <div class="content-area">';

  // User info
  body += '    <div class="card" style="padding:24px;margin-bottom:24px;" id="userInfoCard">';
  body += '      <div class="loading"><div class="spinner"></div>加载中...</div>';
  body += '    </div>';

  // Pet profiles
  body += '    <h2 class="section-title"><span class="icon">🐾</span> 我的毛孩子</h2>';
  body += '    <div id="petList">';
  body += '      <div class="loading"><div class="spinner"></div>加载中...</div>';
  body += '    </div>';

  // Add pet form
  body += '    <div class="card" style="padding:24px;margin-top:24px;" id="addPetCard">';
  body += '      <h3 class="section-title" style="font-size:1.15rem;"><span class="icon">➕</span> 添加毛孩子</h3>';
  body += '      <div class="form-row">';
  body += '        <div class="form-group">';
  body += '          <label class="form-label">宠物昵称 <span style="color:var(--accent);">*</span></label>';
  body += '          <input type="text" class="form-input" id="petName" placeholder="例如：小橘">';
  body += '        </div>';
  body += '        <div class="form-group">';
  body += '          <label class="form-label">宠物类型 <span style="color:var(--accent);">*</span></label>';
  body += '          <select class="form-input" id="petType">';
  body += '            <option value="cat">猫咪 🐱</option>';
  body += '            <option value="dog">狗狗 🐶</option>';
  body += '            <option value="rabbit">兔子 🐰</option>';
  body += '            <option value="hamster">仓鼠 🐹</option>';
  body += '            <option value="bird">鸟类 🐦</option>';
  body += '            <option value="fish">鱼类 🐟</option>';
  body += '            <option value="reptile">爬行类 🦎</option>';
  body += '            <option value="other">其他</option>';
  body += '          </select>';
  body += '        </div>';
  body += '      </div>';
  body += '      <div class="form-row">';
  body += '        <div class="form-group">';
  body += '          <label class="form-label">品种</label>';
  body += '          <input type="text" class="form-input" id="petBreed" placeholder="例如：英短蓝猫">';
  body += '        </div>';
  body += '        <div class="form-group">';
  body += '          <label class="form-label">性别</label>';
  body += '          <select class="form-input" id="petGender">';
  body += '            <option value="unknown">未知</option>';
  body += '            <option value="male">公</option>';
  body += '            <option value="female">母</option>';
  body += '          </select>';
  body += '        </div>';
  body += '      </div>';
  body += '      <div class="form-row">';
  body += '        <div class="form-group">';
  body += '          <label class="form-label">生日</label>';
  body += '          <input type="date" class="form-input" id="petBirthday">';
  body += '        </div>';
  body += '        <div class="form-group">';
  body += '          <label class="form-label">体重（kg）</label>';
  body += '          <input type="number" class="form-input" id="petWeight" placeholder="例如：4.5" min="0" step="0.1">';
  body += '        </div>';
  body += '      </div>';
  body += '      <button class="btn btn-primary" onclick="addPet()">添加宠物</button>';
  body += '    </div>';

  body += '  </div>';

  // Sidebar
  body += '  <aside class="sidebar">';
  body += '    <div class="widget">';
  body += '      <h3 class="widget-title">💡 养宠小贴士</h3>';
  body += '      <p style="font-size:0.88rem;color:var(--muted);line-height:1.7;">为你的毛孩子建立完整的档案，记录成长点滴。定期更新体重和健康信息，有助于及时发现健康问题。</p>';
  body += '    </div>';

  body += '    <div class="widget">';
  body += '      <h3 class="widget-title">🔧 快捷工具</h3>';
  body += '      <div style="display:flex;flex-direction:column;gap:8px;">';
  body += '        <a href="/tools#pet-age" class="btn btn-outline btn-sm" style="text-align:left;">🎂 宠物年龄计算</a>';
  body += '        <a href="/tools#feed" class="btn btn-outline btn-sm" style="text-align:left;">🍖 喂食量计算</a>';
  body += '        <a href="/tools#bmi" class="btn btn-outline btn-sm" style="text-align:left;">⚖️ BMI健康评估</a>';
  body += '        <a href="/tools#deworm" class="btn btn-outline btn-sm" style="text-align:left;">💊 驱虫提醒</a>';
  body += '      </div>';
  body += '    </div>';

  body += '    <div class="ad-banner">广告位</div>';
  body += '  </aside>';
  body += '</div>';
%>

<%
  var pageScript = '';
  pageScript += '<script>';
  pageScript += '(function() {';
  pageScript += '  const typeEmojis = { cat: "🐱", dog: "🐶", rabbit: "🐰", hamster: "🐹", bird: "🐦", fish: "🐟", reptile: "🦎", other: "🐾" };';
  pageScript += '  const typeNames = { cat: "猫咪", dog: "狗狗", rabbit: "兔子", hamster: "仓鼠", bird: "鸟类", fish: "鱼类", reptile: "爬行类", other: "其他" };';
  pageScript += '  const genderNames = { male: "♂️ 公", female: "♀️ 母", unknown: "未知" };';

  pageScript += '  // Load user info and pets';
  pageScript += '  async function loadProfile() {';
  pageScript += '    const token = localStorage.getItem("token");';
  pageScript += '    if (!token) {';
  pageScript += '      document.getElementById("userInfoCard").innerHTML = \'<div class="empty-state"><div class="empty-icon">🔒</div><p>请先<a href="/login">登录</a>查看</p></div>\';';
  pageScript += '      document.getElementById("petList").innerHTML = \'<div class="empty-state"><div class="empty-icon">🔒</div><p>请先登录</p></div>\';';
  pageScript += '      document.getElementById("addPetCard").style.display = "none";';
  pageScript += '      return;';
  pageScript += '    }';
  pageScript += '    try {';
  pageScript += '      const res = await authFetch("/api/auth/me");';
  pageScript += '      const data = await res.json();';
  pageScript += '      if (data.code === 200) {';
  pageScript += '        const user = data.data.user;';
  pageScript += '        const pets = data.data.pets || [];';

  pageScript += '        // Render user info';
  pageScript += '        document.getElementById("userInfoCard").innerHTML =';
  pageScript += '          \'<div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">\' +';
  pageScript += '            \'<div style="width:56px;height:56px;border-radius:50%;background:var(--rule);display:flex;align-items:center;justify-content:center;font-size:2rem;">\' + (user.avatar || "🐱") + \'</div>\' +';
  pageScript += '            \'<div><div style="font-size:1.15rem;font-weight:700;">\' + escapeHtml(user.username) + \'</div>\' +';
  pageScript += '            \'<div style="font-size:0.85rem;color:var(--muted);">注册时间：\' + formatDate(user.created_at) + \' | 宠物数量：\' + pets.length + \'</div></div>\' +';
  pageScript += '          \'</div>\';';

  pageScript += '        // Render pets';
  pageScript += '        if (pets.length > 0) {';
  pageScript += '          document.getElementById("petList").innerHTML = pets.map(p => {';
  pageScript += '            const emoji = typeEmojis[p.pet_type] || "🐾";';
  pageScript += '            const typeName = typeNames[p.pet_type] || "其他";';
  pageScript += '            const gender = genderNames[p.gender] || "未知";';
  pageScript += '            let info = typeName + " | " + gender;';
  pageScript += '            if (p.breed) info += " | " + p.breed;';
  pageScript += '            if (p.weight) info += " | " + p.weight + "kg";';
  pageScript += '            if (p.birthday) info += " | 生日：" + p.birthday;';
  pageScript += '            const avatarHtml = p.avatar_url';
  pageScript += '              ? \'<div class="pet-avatar"><img src="\' + p.avatar_url + \'"></div>\'';
  pageScript += '              : \'<div class="pet-avatar">\' + emoji + \'</div>\';';
  pageScript += '            return \'<div class="pet-card">\' + avatarHtml +';
  pageScript += '              \'<div class="pet-info"><h3>\' + escapeHtml(p.pet_name) + \'</h3><p>\' + info + \'</p></div></div>\';';
  pageScript += '          }).join("");';
  pageScript += '        } else {';
  pageScript += '          document.getElementById("petList").innerHTML = \'<div class="empty-state"><div class="empty-icon">🐾</div><p>还没有添加毛孩子，快来添加第一只吧！</p></div>\';';
  pageScript += '        }';
  pageScript += '      } else {';
  pageScript += '        showToast(data.message || "获取信息失败", "error");';
  pageScript += '      }';
  pageScript += '    } catch(e) { console.error(e); showToast("网络错误", "error"); }';
  pageScript += '  }';

  pageScript += '  // Add pet (via creating a post or direct API if available)';
  pageScript += '  window.addPet = async function() {';
  pageScript += '    const token = localStorage.getItem("token");';
  pageScript += '    if (!token) { openModal("loginModal"); return; }';
  pageScript += '    const petName = document.getElementById("petName").value.trim();';
  pageScript += '    const petType = document.getElementById("petType").value;';
  pageScript += '    if (!petName) { showToast("请输入宠物昵称", "error"); return; }';
  pageScript += '    const breed = document.getElementById("petBreed").value.trim();';
  pageScript += '    const gender = document.getElementById("petGender").value;';
  pageScript += '    const birthday = document.getElementById("petBirthday").value || null;';
  pageScript += '    const weight = parseFloat(document.getElementById("petWeight").value) || null;';

  pageScript += '    // Register with pet info via auth API';
  pageScript += '    try {';
  pageScript += '      const res = await authFetch("/api/auth/register", {';
  pageScript += '        method: "POST",';
  pageScript += '        headers: { "Content-Type": "application/json" },';
  pageScript += '        body: JSON.stringify({ username: "placeholder", email: "placeholder@temp.com", password: "temppass123", petName, petType, avatar: "🐱" })';
  pageScript += '      });';
  pageScript += '      // This won\'t work for adding pets to existing user. Show info instead.';
  pageScript += '      showToast("宠物添加功能需要后端支持单独的宠物API，目前可通过注册时添加宠物信息", "info");';
  pageScript += '    } catch(e) { showToast("操作失败", "error"); }';
  pageScript += '  };';

  pageScript += '  loadProfile();';
  pageScript += '})();';
  pageScript += '</script>';
%>

<%- include('layout', { title: title, bodyClass: 'page-petprofile', body: body, pageScript: pageScript }) %>
