            <p>点击上传图片（支持JPG/PNG，最多9张）</p>
          </div>
          <input type="file" id="imageInput" accept="image/*" multiple style="display:none;" onchange="handleImageUpload(this)">
          <div class="upload-preview" id="imagePreview"></div>
        </div>
        <div class="form-group">
          <label class="form-label">上传视频</label>
          <div class="upload-area" id="videoUploadArea" onclick="document.getElementById('videoInput').click()">
            <div class="upload-icon">🎬</div>
            <p>点击上传视频（支持MP4，最多1个）</p>
          </div>
          <input type="file" id="videoInput" accept="video/*" style="display:none;" onchange="handleVideoUpload(this)">
          <div class="upload-preview" id="videoPreview"></div>
        </div>
        <p id="postError" style="color:#e74c3c;font-size:0.85rem;display:none;margin-bottom:10px;"></p>
        <button class="btn btn-primary" style="width:100%;" onclick="handleCreatePost()">发 布</button>
