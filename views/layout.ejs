          <div class="user-info" onclick="toggleUserMenu()">
            <div class="avatar" id="userAvatar">🐱</div>
            <span class="username" id="userDisplayName">用户</span>
            <span class="logout-btn" onclick="event.stopPropagation(); logout();">退出</span>
          </div>
