          <label class="form-label">标题</label>
          <input type="text" class="form-input" id="postTitle" placeholder="请输入标题" maxlength="200">
        </div>
        <div class="form-group">
          <label class="form-label">内容</label>
          <div id="postEditor" style="min-height:200px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;"></div>
          <input type="hidden" id="postContent">
        </div>
        <div class="form-group">
          <label class="form-label">上传图片</label>
          <div class="upload-area" id="imageUploadArea" onclick="document.getElementById('imageInput').click()">
