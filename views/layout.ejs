    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('avatar-opt')) {
        document.querySelectorAll('.avatar-opt').forEach(el => {
          el.style.borderColor = 'transparent';
        });
        e.target.style.borderColor = 'var(--accent)';
        selectedAvatar = e.target.dataset.avatar;
      }
    });

    /* ===== Modal Management ===== */
    function requireLoginThen(callback) {
      const token = localStorage.getItem('token');
      if (!token) {
        showToast('请先登录后再操作', 'info');
        openModal('loginModal');
        return;
      }
      callback();
    }

    function openModal(id) {
      document.getElementById(id).classList.add('active');
      document.body.style.overflow = 'hidden';
      if (id === 'postModal') {
        setTimeout(initQuillEditor, 100);
      }
    }
    function closeModal(id) {
      document.getElementById(id).classList.remove('active');
      document.body.style.overflow = '';
    }
    // Close modal on overlay click
    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('modal-overlay') && e.target.classList.contains('active')) {
        e.target.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
    // Close modal on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.modal-overlay.active').forEach(m => {
          m.classList.remove('active');
        });
        document.body.style.overflow = '';
      }
    });

    /* ===== Search ===== */
    document.getElementById('headerSearch').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        const keyword = this.value.trim();
        if (keyword) {
          window.location.href = '/search?keyword=' + encodeURIComponent(keyword);
        }
      }
    });

    /* ===== Mobile Nav ===== */
    function toggleMobileNav() {
      document.getElementById('mobileNav').classList.toggle('open');
      document.getElementById('mobileNavOverlay').classList.toggle('open');
    }
    function closeMobileNav() {
      document.getElementById('mobileNav').classList.remove('open');
      document.getElementById('mobileNavOverlay').classList.remove('open');
    }

    /* ===== Toast ===== */
    function showToast(message, type = 'info') {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = 'toast ' + type;
      toast.textContent = message;
      container.appendChild(toast);
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(40px)';
        toast.style.transition = '0.3s ease';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    /* ===== Quill Editor ===== */
    let quillEditor = null;
    function initQuillEditor() {
      if (quillEditor) return;
      quillEditor = new Quill('#postEditor', {
        theme: 'snow',
        placeholder: '分享你的养宠经验...',
        modules: {
          toolbar: [
            [{ 'header': [1, 2, 3, false] }],
            ['bold', 'italic', 'underline', 'strike'],
            [{ 'color': [] }, { 'background': [] }],
            [{ 'list': 'ordered' }, { 'list': 'bullet' }],
            [{ 'align': [] }],
            ['link', 'image'],
            ['clean']
          ]
        }
      });
      var toolbar = quillEditor.getModule('toolbar');
      toolbar.addHandler('image', function() {
        var input = document.createElement('input');
        input.setAttribute('type', 'file');
        input.setAttribute('accept', 'image/*');
        input.click();
        input.onchange = async function() {
          var files = Array.from(input.files);
          if (files.length === 0) return;
          var formData = new FormData();
          files.forEach(function(f) { formData.append('images', f); });
          try {
            var res = await authFetch('/api/upload/images', { method: 'POST', body: formData });
            var data = await res.json();
            if (data.code === 200) {
              var range = quillEditor.getSelection(true);
              data.data.forEach(function(f) {
                quillEditor.insertEmbed(range.index, 'image', f.url);
                range.index += 1;
              });
              quillEditor.setSelection(range.index);
              showToast('图片插入成功', 'success');
            } else {
              showToast(data.message || '上传失败', 'error');
            }
          } catch(e) { showToast('上传失败', 'error'); }
        };
      });
    }

    /* ===== Create Post ===== */
    window.selectedTemplate = '';
    function selectTemplate(btn, template) {
      document.querySelectorAll('#templateSelector .template-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      window.selectedTemplate = template;
      // 根据模板预设内容
      if (!quillEditor) initQuillEditor();
      let presetContent = '';
      if (template === 'medical') {
        presetContent = '<h3>🩺 症状描述</h3><p>请详细描述宠物的症状、持续时间、频率...</p><h3>🔍 原因分析</h3><p>您猜测可能的原因...</p><h3>🏠 居家处理</h3><p>已经尝试的处理方式及效果...</p><h3>⚠️ 就医提醒</h3><p>是否需要就医，已预约的医院...</p>';
      } else if (template === 'adoption') {
        presetContent = '<h3>🐾 宠物信息</h3><p>品种、年龄、性别、健康状况、疫苗/绝育情况...</p><h3>📍 所在城市</h3><p>领养所在城市及送养方式...</p><h3>📋 领养要求</h3><p>对领养人的要求...</p><h3>📞 联系方式</h3><p>如何联系您...</p>';
      } else if (template === 'review') {
        presetContent = '<h3>📦 产品信息</h3><p>品牌、型号、购买渠道、价格...</p><h3>✅ 优点</h3><p>...</p><h3>❌ 缺点</h3><p>...</p><h3>💡 综合评价</h3><p>是否推荐，适合什么样的宠物...</p>';
      } else if (template === 'showpet') {
        presetContent = '<p>分享你家毛孩子的可爱瞬间！可以写写名字、年龄、性格特点...</p>';
      }
      if (presetContent) {
        quillEditor.root.innerHTML = presetContent;
      }
    }

    async function handleCreatePost() {
      const token = localStorage.getItem('token');
      if (!token) {
        showToast('请先登录', 'error');
        openModal('loginModal');
        return;
      }

      const category = document.getElementById('postCategory').value;
      const title = document.getElementById('postTitle').value.trim();
      const content = quillEditor ? quillEditor.root.innerHTML.trim() : '';
      const errorEl = document.getElementById('postError');

      if (!category) {
        errorEl.textContent = '请选择所属板块';
        errorEl.style.display = 'block';
        return;
      }
      if (!title || !content || content === '<p><br></p>') {
        errorEl.textContent = '标题和内容不能为空';
        errorEl.style.display = 'block';
        return;
      }

      try {
        const media = [];
        uploadedImages.forEach(url => media.push({ type: 'image', url }));
        uploadedVideos.forEach(url => media.push({ type: 'video', url }));

        const res = await authFetch('/api/posts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title, content, post_type: 'forum', category, post_template: window.selectedTemplate, media, city: (currentUser && currentUser.city) || '' })
        });
        const data = await res.json();
        if (data.code === 201 || data.code === 200) {
          closeModal('postModal');
          showToast('发布成功！', 'success');
          document.getElementById('postTitle').value = '';
          document.getElementById('postCategory').value = '';
          if (quillEditor) quillEditor.setContents([]);
          uploadedImages = [];
          uploadedVideos = [];
          document.getElementById('imagePreview').innerHTML = '';
          document.getElementById('videoPreview').innerHTML = '';
          setTimeout(() => location.reload(), 800);
        } else {
          errorEl.textContent = data.message || '发布失败';
          errorEl.style.display = 'block';
        }
      } catch (err) {
        errorEl.textContent = '网络错误，请稍后重试';
        errorEl.style.display = 'block';
      }
    }

    /* ===== File Upload ===== */
    async function handleImageUpload(input) {
      const files = Array.from(input.files);
      if (files.length === 0) return;

      const formData = new FormData();
      files.forEach(f => formData.append('images', f));

      try {
        const res = await authFetch('/api/upload/images', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.code === 200) {
          data.data.forEach(f => {
            uploadedImages.push(f.url);
            addImagePreview(f.url);
          });
          showToast('图片上传成功', 'success');
        } else {
          showToast(data.message || '上传失败', 'error');
        }
      } catch (err) {
        showToast('上传失败', 'error');
      }
      input.value = '';
    }

    async function handleVideoUpload(input) {
      const files = Array.from(input.files);
      if (files.length === 0) return;

      const formData = new FormData();
      files.forEach(f => formData.append('videos', f));

      try {
        const res = await authFetch('/api/upload/videos', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.code === 200) {
          data.data.forEach(f => {
            uploadedVideos.push(f.url);
            addVideoPreview(f.url);
          });
          showToast('视频上传成功', 'success');
        } else {
          showToast(data.message || '上传失败', 'error');
        }
      } catch (err) {
        showToast('上传失败', 'error');
      }
      input.value = '';
    }

    function addImagePreview(url) {
      const container = document.getElementById('imagePreview');
      const div = document.createElement('div');
      div.className = 'preview-item';
      div.innerHTML = '<img src="' + url + '"><div class="remove-btn" onclick="removeImage(this, \'' + url + '\')">✕</div>';
      container.appendChild(div);
    }

    function addVideoPreview(url) {
      const container = document.getElementById('videoPreview');
      const div = document.createElement('div');
      div.className = 'preview-item';
      div.innerHTML = '<video src="' + url + '"></video><div class="remove-btn" onclick="removeVideo(this, \'' + url + '\')">✕</div>';
      container.appendChild(div);
    }

    function removeImage(btn, url) {
      uploadedImages = uploadedImages.filter(u => u !== url);
      btn.parentElement.remove();
    }

    function removeVideo(btn, url) {
      uploadedVideos = uploadedVideos.filter(u => u !== url);
      btn.parentElement.remove();
    }

    /* ===== Date Format ===== */
    function formatDate(dateStr) {
      if (!dateStr) return '';
      const d = new Date(dateStr);
      const now = new Date();
      const diff = now - d;
      if (diff < 60000) return '刚刚';
      if (diff < 3600000) return Math.floor(diff / 60000) + '分钟前';
      if (diff < 86400000) return Math.floor(diff / 3600000) + '小时前';
      if (diff < 604800000) return Math.floor(diff / 86400000) + '天前';
      return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
    }

    /* ===== Render Helpers ===== */
    function renderPostItem(post) {
      const images = post.images ? post.images.split(',') : [];
      const thumbHtml = images.length > 0
        ? '<img class="post-thumb" src="' + images[0] + '" alt="' + escapeHtml(post.title || '帖子图片') + '" loading="lazy">'
        : '';
      const avatarHtml = (post.user_avatar_url || post.avatar)
        ? '<div class="post-avatar">' + (post.user_avatar_url ? '<img src="' + post.user_avatar_url + '">' : post.avatar) + '</div>'
        : '<div class="post-avatar">🐱</div>';
      return '<div class="post-item">' +
        avatarHtml +
        '<div class="post-content">' +
          '<div class="post-header">' +
            '<span class="post-author">' + (post.username || '匿名') + '</span>' +
            '<span class="post-time">' + formatDate(post.created_at) + '</span>' +
            (post.is_pinned ? '<span class="tag tag-purple">置顶</span>' : '') +
          '</div>' +
          '<div class="post-title-text"><a href="/post/' + (post.slug || post.id) + '">' + escapeHtml(post.title) + '</a></div>' +
          '<div class="post-desc">' + escapeHtml(stripHtml(post.content)) + '</div>' +
          '<div class="post-footer">' +
            '<span>👁 ' + (post.view_count || 0) + '</span>' +
            '<span>❤️ ' + (post.like_count || 0) + '</span>' +
            '<span>💬 ' + (post.comment_count || 0) + '</span>' +
          '</div>' +
        '</div>' +
        thumbHtml +
      '</div>';
    }

    function renderArticleCard(post) {
      const images = post.images ? post.images.split(',') : [];
      const imgHtml = images.length > 0
        ? '<img class="card-img" src="' + images[0] + '" alt="' + escapeHtml(post.title || '帖子图片') + '" loading="lazy">'
        : '<div class="card-img" style="display:flex;align-items:center;justify-content:center;font-size:2.5rem;background:var(--rule);" role="img" aria-label="暂无图片">🐾</div>';
      return '<div class="card">' +
        '<a href="/post/' + (post.slug || post.id) + '">' + imgHtml + '</a>' +
        '<div class="card-body">' +
          '<div class="card-title"><a href="/post/' + (post.slug || post.id) + '">' + escapeHtml(post.title) + '</a></div>' +
          '<div class="card-excerpt">' + escapeHtml(stripHtml(post.content)) + '</div>' +
          '<div class="card-meta">' +
            '<span class="author"><span class="emoji">' + (post.avatar || '🐱') + '</span> ' + (post.username || '匿名') + '</span>' +
            '<span>' + formatDate(post.created_at) + '</span>' +
            '<span>👁 ' + (post.view_count || 0) + '</span>' +
          '</div>' +
        '</div>' +
      '</div>';
    }

    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
    function stripHtml(str) {
      if (!str) return '';
      return str.replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
    }

    /* ===== Pagination Helper ===== */
    function renderPagination(total, page, limit, callback) {
      const totalPages = Math.ceil(total / limit);
      if (totalPages <= 1) return '';
      let html = '<div class="pagination">';
      html += '<button class="page-btn ' + (page <= 1 ? 'disabled' : '') + '" ' + (page > 1 ? 'onclick="' + callback + '(' + (page - 1) + ')"' : '') + '>&laquo;</button>';
      for (let i = 1; i <= totalPages; i++) {
        if (totalPages > 7 && i > 3 && i < totalPages - 1 && Math.abs(i - page) > 1) {
          if (i === 4 || i === totalPages - 2) html += '<span style="color:var(--muted);">...</span>';
          continue;
        }
        html += '<button class="page-btn ' + (i === page ? 'active' : '') + '" onclick="' + callback + '(' + i + ')">' + i + '</button>';
      }
      html += '<button class="page-btn ' + (page >= totalPages ? 'disabled' : '') + '" ' + (page < totalPages ? 'onclick="' + callback + '(' + (page + 1) + ')"' : '') + '>&raquo;</button>';
      html += '</div>';
      return html;
    }
  </script>

  <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.min.js"></script>
  <!-- Page-specific scripts placeholder -->
  <%- typeof pageScript !== 'undefined' ? pageScript : '' %>


  <!-- Scroll to Top -->
  <button class="scroll-top" id="scrollTopBtn" aria-label="返回顶部" title="返回顶部">&#x2191;</button>

  <!-- Toast Container -->
  <div class="toast-container" id="toastContainer"></div>

  <script>
  (function() {
    // Lazy load image handling
    function handleLazyImages() {
      const lazyImages = document.querySelectorAll('img[loading="lazy"]');
      lazyImages.forEach(function(img) {
        if (img.complete && img.naturalHeight !== 0) {
          img.classList.add('loaded');
        } else {
          img.addEventListener('load', function() {
            this.classList.add('loaded');
          });
          img.addEventListener('error', function() {
            this.classList.add('loaded');
          });
        }
      });
    }
    // Run on DOM ready and after dynamic content loads
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', handleLazyImages);
    } else {
      handleLazyImages();
    }
    // Also expose for dynamic content
    window.refreshLazyImages = handleLazyImages;

    // Scroll to top button
    var scrollBtn = document.getElementById('scrollTopBtn');
    if (scrollBtn) {
      window.addEventListener('scroll', function() {
        if (window.scrollY > 400) {
          scrollBtn.classList.add('visible');
        } else {
          scrollBtn.classList.remove('visible');
        }
      });
      scrollBtn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // Enhanced showToast if not defined
    if (typeof window.showToast !== 'function') {
      window.showToast = function(message, type) {
        type = type || 'info';
        var container = document.getElementById('toastContainer');
        if (!container) return;
        var toast = document.createElement('div');
        toast.className = 'toast ' + type;
        var icon = type === 'success' ? '&#x2714;' : type === 'error' ? '&#x2716;' : type === 'warning' ? '&#x26A0;' : '&#x2139;';
        toast.innerHTML = '<span style="font-size:1.1rem;">' + icon + '</span><span>' + escapeHtml(message) + '</span>';
        container.appendChild(toast);
        setTimeout(function() {
          toast.classList.add('toast-hide');
          setTimeout(function() { toast.remove(); }, 350);
        }, 3000);
      };
    }
  })();
  </script>
</body>
</html>
