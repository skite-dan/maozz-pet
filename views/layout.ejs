  <meta name="keywords" content="<%= typeof metaKeywords !== 'undefined' ? metaKeywords : '宠物论坛,养猫攻略,养狗教程,猫咪疾病,同城宠物领养,宠物交流社区' %>">
  <meta name="robots" content="<%= typeof metaRobots !== 'undefined' ? metaRobots : 'index, follow' %>">
  <meta property="og:site_name" content="毛茸茸星球">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : '毛茸茸星球' %>">
  <meta property="og:description" content="<%= typeof metaDesc !== 'undefined' ? metaDesc : '毛茸茸星球是铲屎官专属宠物社区，分享猫狗饲养干货、宠物疾病问诊、同城遛宠、无偿领养、宠物用品闲置交流。' %>">
  <meta property="og:type" content="<%= typeof ogType !== 'undefined' ? ogType : 'website' %>">
  <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : (siteUrl || '') + req.path %>">
  <% if (typeof ogImage !== 'undefined' && ogImage) { %>
  <meta property="og:image" content="<%= ogImage %>">
  <% } %>
  <% if (!(typeof ogImage !== 'undefined' && ogImage)) { %>
  <meta property="og:image" content="<%= (typeof siteUrl !== 'undefined' ? siteUrl : '') %>/images/og-default.jpg">
  <% } %>
  <meta property="og:locale" content="zh_CN">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : '毛茸茸星球' %>">
  <meta name="twitter:description" content="<%= typeof metaDesc !== 'undefined' ? metaDesc : '专为铲屎官打造的宠物社区' %>">
  <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' && ogImage ? ogImage : ((typeof siteUrl !== 'undefined' ? siteUrl : '') + '/images/og-default.jpg') %>">
  <link rel="sitemap" type="application/xml" href="<%= siteUrl || '' %>/sitemap.xml">
  <!-- Google Search Console 验证 (请替换为实际验证码) -->
  <meta name="google-site-verification" content="YOUR_GSC_VERIFICATION_CODE_HERE">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "毛茸茸星球",
    "url": "<%= typeof siteUrl !== 'undefined' ? siteUrl : '' %>",
    "description": "毛茸茸星球是铲屎官专属宠物社区，分享猫狗饲养干货、宠物疾病问诊、同城遛宠、无偿领养、宠物用品闲置交流，百万养宠经验免费查阅，一站式解决养宠难题。",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "<%= typeof siteUrl !== 'undefined' ? siteUrl : '' %>/search?keyword={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  <% if (typeof structuredData !== 'undefined' && structuredData) { %>
  <script type="application/ld+json"><%- structuredData %></script>
  <% } %>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">

