  <!-- ========== FAB ========== -->
  <button class="fab" id="fabBtn" onclick="requireLoginThen(function(){ openModal('postModal') })" title="发布新帖">✏️</button>


  <!-- ========== Report Modal ========== -->
  <div class="modal-overlay" id="reportModal">
    <div class="modal" style="max-width:400px;">
      <div class="modal-header">
        <h3>举报帖子</h3>
        <div class="modal-close" onclick="closeModal('reportModal')">&#x2715;</div>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">举报原因</label>
          <select class="form-input" id="reportReason">
            <option value="">请选择</option>
            <option value="spam">垃圾广告</option>
            <option value="fraud">虚假信息/诈骗</option>
            <option value="abuse">人身攻击/辱骂</option>
            <option value="illegal">违法违规内容</option>
            <option value="other">其他</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">详细说明（可选）</label>
          <textarea class="form-input" id="reportDetail" rows="3" placeholder="请补充说明举报原因..."></textarea>
        </div>
        <p id="reportError" style="color:#e74c3c;font-size:0.85rem;display:none;margin-bottom:10px;"></p>
        <button class="btn btn-primary" style="width:100%;" onclick="submitReport()">提交举报</button>
      </div>
    </div>
  </div>
  <!-- ========== Login Modal ========== -->
  <div class="modal-overlay" id="loginModal">
    <div class="modal">
      <div class="modal-header">
        <h3>登录</h3>
        <div class="modal-close" onclick="closeModal('loginModal')">✕</div>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">用户名 / 邮箱</label>
          <input type="text" class="form-input" id="loginUsername" placeholder="请输入用户名或邮箱">
        </div>
        <div class="form-group">
          <label class="form-label">密码 <span style="color:var(--accent);">*</span></label>
          <input type="password" class="form-input" id="loginPassword" placeholder="请输入密码">
        </div>
        <p id="loginError" style="color:#e74c3c;font-size:0.85rem;display:none;margin-bottom:10px;"></p>
        <button class="btn btn-primary" style="width:100%;" onclick="handleLogin()">登 录</button>
      </div>
      <div class="modal-footer">
        <span style="font-size:0.88rem;color:var(--muted);">还没有账号？<a href="/register" style="color:var(--accent);font-weight:600;">去注册</a></span>
      </div>
    </div>
  </div>

  <!-- ========== Register Modal ========== -->
  <div class="modal-overlay" id="registerModal">
    <div class="modal">
      <div class="modal-header">
        <h3>注册</h3>
        <div class="modal-close" onclick="closeModal('registerModal')">✕</div>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">用户名 <span style="color:var(--accent);">*</span></label>
          <input type="text" class="form-input" id="regUsername" placeholder="2-20个字符">
        </div>
        <div class="form-group">
          <label class="form-label">所在城市 <span style="color:var(--accent);">*</span></label>
          <div style="display:flex;gap:10px;">
            <select class="form-input" id="regProvince" style="flex:1;" onchange="updateRegCities()">
              <option value="">选择省份</option>
              <option value="北京">北京</option>
              <option value="天津">天津</option>
              <option value="河北">河北</option>
              <option value="山西">山西</option>
              <option value="内蒙古">内蒙古</option>
              <option value="辽宁">辽宁</option>
              <option value="吉林">吉林</option>
              <option value="黑龙江">黑龙江</option>
              <option value="上海">上海</option>
              <option value="江苏">江苏</option>
              <option value="浙江">浙江</option>
              <option value="安徽">安徽</option>
              <option value="福建">福建</option>
              <option value="江西">江西</option>
              <option value="山东">山东</option>
              <option value="河南">河南</option>
              <option value="湖北">湖北</option>
              <option value="湖南">湖南</option>
              <option value="广东">广东</option>
              <option value="广西">广西</option>
              <option value="海南">海南</option>
              <option value="重庆">重庆</option>
              <option value="四川">四川</option>
              <option value="贵州">贵州</option>
              <option value="云南">云南</option>
              <option value="西藏">西藏</option>
              <option value="陕西">陕西</option>
              <option value="甘肃">甘肃</option>
              <option value="青海">青海</option>
              <option value="宁夏">宁夏</option>
              <option value="新疆">新疆</option>
            </select>
            <select class="form-input" id="regCitySelect" style="flex:1;">
              <option value="">选择城市</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">邮箱 <span style="color:var(--accent);">*</span></label>
          <input type="email" class="form-input" id="regEmail" placeholder="请输入邮箱">
        </div>
        <div class="form-group">
          <label class="form-label">密码 <span style="color:var(--accent);">*</span></label>
          <input type="password" class="form-input" id="regPassword" placeholder="至少6个字符">
        </div>
        <div class="form-group">
          <label class="form-label">头像 <span style="color:var(--accent);">*</span></label>
          <div style="display:flex;gap:8px;flex-wrap:wrap;" id="avatarPicker">
            <span class="avatar-opt" data-avatar="🐱" style="font-size:1.5rem;cursor:pointer;padding:4px;border:2px solid transparent;border-radius:8px;">🐱</span>
            <span class="avatar-opt" data-avatar="🐶" style="font-size:1.5rem;cursor:pointer;padding:4px;border:2px solid transparent;border-radius:8px;">🐶</span>
            <span class="avatar-opt" data-avatar="🐰" style="font-size:1.5rem;cursor:pointer;padding:4px;border:2px solid transparent;border-radius:8px;">🐰</span>
            <span class="avatar-opt" data-avatar="🐹" style="font-size:1.5rem;cursor:pointer;padding:4px;border:2px solid transparent;border-radius:8px;">🐹</span>
            <span class="avatar-opt" data-avatar="🐦" style="font-size:1.5rem;cursor:pointer;padding:4px;border:2px solid transparent;border-radius:8px;">🐦</span>
            <span class="avatar-opt" data-avatar="🐟" style="font-size:1.5rem;cursor:pointer;padding:4px;border:2px solid transparent;border-radius:8px;">🐟</span>
            <span class="avatar-opt" data-avatar="🦎" style="font-size:1.5rem;cursor:pointer;padding:4px;border:2px solid transparent;border-radius:8px;">🦎</span>
            <span class="avatar-opt" data-avatar="🦜" style="font-size:1.5rem;cursor:pointer;padding:4px;border:2px solid transparent;border-radius:8px;">🦜</span>
          </div>
        </div>
        <div style="border-top:1px solid var(--rule);padding-top:16px;margin-top:8px;">
          <p style="font-size:0.88rem;color:var(--muted);margin-bottom:12px;">选填：添加你的第一个毛孩子</p>
          <div style="display:flex;gap:10px;">
            <div class="form-group" style="flex:1;">
              <label class="form-label">宠物名字</label>
              <input type="text" class="form-input" id="regPetName" placeholder="例如：小橘">
            </div>
            <div class="form-group" style="flex:1;">
              <label class="form-label">宠物类型</label>
              <select class="form-input" id="regPetType">
                <option value="cat">猫咪</option>
                <option value="dog">狗狗</option>
                <option value="rabbit">兔子</option>
                <option value="hamster">仓鼠</option>
                <option value="bird">鸟类</option>
                <option value="fish">鱼类</option>
                <option value="reptile">爬行类</option>
                <option value="other">其他</option>
              </select>
            </div>
          </div>
        </div>

        <p id="regError" style="color:#e74c3c;font-size:0.85rem;display:none;margin-bottom:10px;"></p>
        <button class="btn btn-primary" style="width:100%;" onclick="handleRegister()">注 册</button>
      </div>
      <div class="modal-footer">
        <span style="font-size:0.88rem;color:var(--muted);">已有账号？<a href="/login" style="color:var(--accent);font-weight:600;">去登录</a></span>
      </div>
    </div>
  </div>

  <!-- ========== Post Modal ========== -->
  <div class="modal-overlay" id="postModal">
    <div class="modal" style="max-width:600px;">
      <div class="modal-header">
        <h3>发布新帖</h3>
        <div class="modal-close" onclick="closeModal('postModal')">✕</div>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">选择发帖模板（可选）</label>
          <div class="template-selector" id="templateSelector">
            <button type="button" class="template-btn active" data-template="" onclick="selectTemplate(this,'')">📝 自由发帖</button>
            <button type="button" class="template-btn" data-template="medical" onclick="selectTemplate(this,'medical')">🏥 问诊帖</button>
            <button type="button" class="template-btn" data-template="adoption" onclick="selectTemplate(this,'adoption')">🏠 领养帖</button>
            <button type="button" class="template-btn" data-template="review" onclick="selectTemplate(this,'review')">⭐ 测评帖</button>
            <button type="button" class="template-btn" data-template="showpet" onclick="selectTemplate(this,'showpet')">📸 晒宠帖</button>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">所属板块</label>
          <select class="form-input" id="postCategory">
            <option value="">请选择板块</option>
