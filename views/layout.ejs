    /* ===== Register ===== */
    async function handleRegister() {
      const username = document.getElementById('regUsername').value.trim();
      const email = document.getElementById('regEmail').value.trim();
      const password = document.getElementById('regPassword').value;
      const petName = document.getElementById('regPetName').value.trim();
      const petType = document.getElementById('regPetType').value;
      const errorEl = document.getElementById('regError');

      if (!username || !email || !password) {
        errorEl.textContent = '请填写所有必填项';
        errorEl.style.display = 'block';
        return;
      }

      try {
        const province = document.getElementById('regProvince').value;
        const city = document.getElementById('regCitySelect').value;
        if (!province || !city) { errorEl.textContent = '请选择所在省份和城市'; errorEl.style.display = 'block'; return; }
        const fullCity = province + '-' + city;
        const body = { username, email, password, avatar: selectedAvatar, city: fullCity };
        if (petName) { body.petName = petName; body.petType = petType; }
        const res = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await res.json();
        if (data.code === 201 || data.code === 200) {
          localStorage.setItem('token', data.data.token);
          localStorage.setItem('user', JSON.stringify(data.data.user));
          if (data.data.user && data.data.user.city) localStorage.setItem('userCity', data.data.user.city);
          currentUser = data.data.user;
          showLoggedInState();
          closeModal('registerModal');
          showToast('注册成功，欢迎加入毛茸茸星球！', 'success');
          setTimeout(() => location.reload(), 800);
        } else {
          errorEl.textContent = data.message || '注册失败';
          errorEl.style.display = 'block';
        }
      } catch (err) {
        errorEl.textContent = '网络错误，请稍后重试';
        errorEl.style.display = 'block';
      }
    }

    /* ===== Logout ===== */
    function logout() {
      localStorage.removeItem('token');
      localStorage.removeItem('user');
      localStorage.removeItem('userCity');
      currentUser = null;
      showGuestState();
      showToast('已退出登录', 'info');
      setTimeout(() => location.reload(), 600);
    }


    /* ===== Report Post ===== */
    var currentReportPostId = null;
    function openReportModal(postId) {
      currentReportPostId = postId;
      document.getElementById('reportReason').value = '';
      document.getElementById('reportDetail').value = '';
      document.getElementById('reportError').style.display = 'none';
      openModal('reportModal');
    }
    async function submitReport() {
      const reason = document.getElementById('reportReason').value;
      const detail = document.getElementById('reportDetail').value;
      const errorEl = document.getElementById('reportError');
      if (!reason) { errorEl.textContent = '请选择举报原因'; errorEl.style.display = 'block'; return; }
      if (!currentReportPostId) { errorEl.textContent = '帖子ID错误'; errorEl.style.display = 'block'; return; }
      try {
        const res = await authFetch('/api/posts/' + currentReportPostId + '/report', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ reason, detail })
        });
        const data = await res.json();
        if (data.code === 200) {
          closeModal('reportModal');
          showToast('举报成功，我们会尽快处理', 'success');
        } else {
          errorEl.textContent = data.message || '举报失败';
          errorEl.style.display = 'block';
        }
      } catch(e) {
        errorEl.textContent = '网络错误';
        errorEl.style.display = 'block';
      }
    }

