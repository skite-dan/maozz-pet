    function updateRegCities() {
      var province = document.getElementById('regProvince').value;
      var citySel = document.getElementById('regCitySelect');
      citySel.innerHTML = '<option value="">选择城市</option>';
      if (province && provinceCityMap[province]) {
        provinceCityMap[province].forEach(function(city) {
          var opt = document.createElement('option');
          opt.value = city;
          opt.textContent = city;
          citySel.appendChild(opt);
        });
