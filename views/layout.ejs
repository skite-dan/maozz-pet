  <!-- ========== Toast Container ========== -->
  <div class="toast-container" id="toastContainer"></div>

  <!-- ========== Common JavaScript ========== -->
  <script>
    /* ===== User Auth State ===== */
    let currentUser = null;
    let selectedAvatar = '🐱';
    let uploadedImages = [];
    let uploadedVideos = [];

    (function initAuth() {
      const token = localStorage.getItem('token');
      const user = localStorage.getItem('user');
      if (token && user) {
        try {
          currentUser = JSON.parse(user);
          showLoggedInState();
        } catch (e) {
          localStorage.removeItem('token');
          localStorage.removeItem('user');
        }
      }
    })();

    function showLoggedInState() {
      document.getElementById('guestBtns').style.display = 'none';
      document.getElementById('loggedInUser').style.display = 'block';
      document.getElementById('userDisplayName').textContent = currentUser.username || '用户';
      const avatarEl = document.getElementById('userAvatar');
      if (currentUser.avatar_url) {
        avatarEl.innerHTML = '<img src="' + currentUser.avatar_url + '" alt="avatar">';
      } else {
        avatarEl.textContent = currentUser.avatar || '🐱';
      }
    }

    function showGuestState() {
      document.getElementById('guestBtns').style.display = 'flex';
      document.getElementById('loggedInUser').style.display = 'none';
    }

    /* ===== Authenticated Fetch ===== */
    async function authFetch(url, options = {}) {
      const token = localStorage.getItem('token');
      if (token) {
        options.headers = options.headers || {};
        options.headers['Authorization'] = 'Bearer ' + token;
      }
      return fetch(url, options);
    }

    /* ===== Login ===== */
    async function handleLogin() {
      const username = document.getElementById('loginUsername').value.trim();
      const password = document.getElementById('loginPassword').value;
      const errorEl = document.getElementById('loginError');

      if (!username || !password) {
        errorEl.textContent = '请输入用户名和密码';
        errorEl.style.display = 'block';
        return;
      }

      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password })
        });
        const data = await res.json();
        if (data.code === 200) {
          localStorage.setItem('token', data.data.token);
          localStorage.setItem('user', JSON.stringify(data.data.user));
          currentUser = data.data.user;
          showLoggedInState();
          closeModal('loginModal');
          showToast('登录成功，欢迎回来！', 'success');
          setTimeout(() => location.reload(), 800);
        } else {
          errorEl.textContent = data.message || '登录失败';
          errorEl.style.display = 'block';
        }
      } catch (err) {
        errorEl.textContent = '网络错误，请稍后重试';
        errorEl.style.display = 'block';
      }
    }

    /* ===== Register ===== */
    async function handleRegister() {
      const username = document.getElementById('regUsername').value.trim();
      const email = document.getElementById('regEmail').value.trim();
      const password = document.getElementById('regPassword').value;
      const errorEl = document.getElementById('regError');

      if (!username || !email || !password) {
        errorEl.textContent = '请填写所有必填项';
        errorEl.style.display = 'block';
        return;
      }

      try {
        const res = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, email, password, avatar: selectedAvatar })
        });
        const data = await res.json();
        if (data.code === 201 || data.code === 200) {
          localStorage.setItem('token', data.data.token);
          localStorage.setItem('user', JSON.stringify(data.data.user));
          currentUser = data.data.user;
          showLoggedInState();
          closeModal('registerModal');
          showToast('注册成功，欢迎加入毛茸茸星球！', 'success');
          setTimeout(() => location.reload(), 800);
        } else {
          errorEl.textContent = data.message || '注册失败';
          errorEl.style.display = 'block';
        }
      } catch (err) {
        errorEl.textContent = '网络错误，请稍后重试';
        errorEl.style.display = 'block';
      }
    }

    /* ===== Logout ===== */
    function logout() {
      localStorage.removeItem('token');
      localStorage.removeItem('user');
      currentUser = null;
      showGuestState();
      showToast('已退出登录', 'info');
      setTimeout(() => location.reload(), 600);
    }

    /* ===== Avatar Picker ===== */
    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('avatar-opt')) {
        document.querySelectorAll('.avatar-opt').forEach(el => {
          el.style.borderColor = 'transparent';
        });
        e.target.style.borderColor = 'var(--accent)';
        selectedAvatar = e.target.dataset.avatar;
      }
    });

    /* ===== Modal Management ===== */
    function openModal(id) {
      document.getElementById(id).classList.add('active');
      document.body.style.overflow = 'hidden';
      if (id === 'postModal') {
        setTimeout(initQuillEditor, 100);
      }
    }
    function closeModal(id) {
      document.getElementById(id).classList.remove('active');
      document.body.style.overflow = '';
    }
    // Close modal on overlay click
    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('modal-overlay') && e.target.classList.contains('active')) {
        e.target.classList.remove('active');
        document.body.style.overflow = '';
      }
    });
    // Close modal on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.modal-overlay.active').forEach(m => {
          m.classList.remove('active');
        });
        document.body.style.overflow = '';
      }
    });

    /* ===== Search ===== */
    document.getElementById('headerSearch').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        const keyword = this.value.trim();
        if (keyword) {
          window.location.href = '/search?keyword=' + encodeURIComponent(keyword);
        }
      }
    });

    /* ===== Mobile Nav ===== */
    function toggleMobileNav() {
      document.getElementById('mobileNav').classList.toggle('open');
      document.getElementById('mobileNavOverlay').classList.toggle('open');
    }
    function closeMobileNav() {
      document.getElementById('mobileNav').classList.remove('open');
      document.getElementById('mobileNavOverlay').classList.remove('open');
    }

    /* ===== Toast ===== */
    function showToast(message, type = 'info') {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = 'toast ' + type;
      toast.textContent = message;
      container.appendChild(toast);
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(40px)';
        toast.style.transition = '0.3s ease';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    /* ===== Quill Editor ===== */
    let quillEditor = null;
    function initQuillEditor() {
      if (quillEditor) return;
      quillEditor = new Quill('#postEditor', {
        theme: 'snow',
        placeholder: '分享你的养宠经验...',
        modules: {
          toolbar: [
            [{ 'header': [1, 2, 3, false] }],
            ['bold', 'italic', 'underline', 'strike'],
            [{ 'color': [] }, { 'background': [] }],
            [{ 'list': 'ordered' }, { 'list': 'bullet' }],
            [{ 'align': [] }],
            ['link', 'image'],
            ['clean']
          ]
        }
      });
    }

    /* ===== Create Post ===== */
    async function handleCreatePost() {
      const token = localStorage.getItem('token');
      if (!token) {
        showToast('请先登录', 'error');
        openModal('loginModal');
        return;
      }

      const postType = document.getElementById('postType').value;
      const title = document.getElementById('postTitle').value.trim();
      const content = quillEditor ? quillEditor.root.innerHTML.trim() : '';
      const errorEl = document.getElementById('postError');

      if (!title || !content || content === '<p><br></p>') {
        errorEl.textContent = '标题和内容不能为空';
        errorEl.style.display = 'block';
        return;
      }

      try {
        const media = [];
        uploadedImages.forEach(url => media.push({ type: 'image', url }));
        uploadedVideos.forEach(url => media.push({ type: 'video', url }));

        const res = await authFetch('/api/posts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title, content, post_type: postType, media })
        });
        const data = await res.json();
        if (data.code === 201 || data.code === 200) {
          closeModal('postModal');
          showToast('发布成功！', 'success');
          document.getElementById('postTitle').value = '';
          if (quillEditor) quillEditor.setContents([]);
          uploadedImages = [];
          uploadedVideos = [];
          document.getElementById('imagePreview').innerHTML = '';
          document.getElementById('videoPreview').innerHTML = '';
          setTimeout(() => location.reload(), 800);
        } else {
          errorEl.textContent = data.message || '发布失败';
          errorEl.style.display = 'block';
        }
      } catch (err) {
        errorEl.textContent = '网络错误，请稍后重试';
        errorEl.style.display = 'block';
      }
    }

    /* ===== File Upload ===== */
    async function handleImageUpload(input) {
      const files = Array.from(input.files);
      if (files.length === 0) return;

      const formData = new FormData();
      files.forEach(f => formData.append('images', f));

      try {
        const res = await authFetch('/api/upload/images', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.code === 200) {
          data.data.forEach(f => {
            uploadedImages.push(f.url);
            addImagePreview(f.url);
          });
          showToast('图片上传成功', 'success');
        } else {
          showToast(data.message || '上传失败', 'error');
        }
      } catch (err) {
        showToast('上传失败', 'error');
      }
      input.value = '';
    }

    async function handleVideoUpload(input) {
      const files = Array.from(input.files);
      if (files.length === 0) return;

      const formData = new FormData();
      files.forEach(f => formData.append('videos', f));

      try {
        const res = await authFetch('/api/upload/videos', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.code === 200) {
          data.data.forEach(f => {
            uploadedVideos.push(f.url);
            addVideoPreview(f.url);
          });
          showToast('视频上传成功', 'success');
        } else {
          showToast(data.message || '上传失败', 'error');
        }
      } catch (err) {
        showToast('上传失败', 'error');
      }
      input.value = '';
    }

    function addImagePreview(url) {
      const container = document.getElementById('imagePreview');
      const div = document.createElement('div');
      div.className = 'preview-item';
      div.innerHTML = '<img src="' + url + '"><div class="remove-btn" onclick="removeImage(this, \'' + url + '\')">✕</div>';
      container.appendChild(div);
    }

    function addVideoPreview(url) {
      const container = document.getElementById('videoPreview');
      const div = document.createElement('div');
      div.className = 'preview-item';
      div.innerHTML = '<video src="' + url + '"></video><div class="remove-btn" onclick="removeVideo(this, \'' + url + '\')">✕</div>';
      container.appendChild(div);
    }

    function removeImage(btn, url) {
      uploadedImages = uploadedImages.filter(u => u !== url);
      btn.parentElement.remove();
    }

    function removeVideo(btn, url) {
      uploadedVideos = uploadedVideos.filter(u => u !== url);
      btn.parentElement.remove();
    }

    /* ===== Date Format ===== */
    function formatDate(dateStr) {
      if (!dateStr) return '';
      const d = new Date(dateStr);
      const now = new Date();
      const diff = now - d;
      if (diff < 60000) return '刚刚';
      if (diff < 3600000) return Math.floor(diff / 60000) + '分钟前';
      if (diff < 86400000) return Math.floor(diff / 3600000) + '小时前';
      if (diff < 604800000) return Math.floor(diff / 86400000) + '天前';
      return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
    }

    /* ===== Render Helpers ===== */
    function renderPostItem(post) {
      const images = post.images ? post.images.split(',') : [];
      const thumbHtml = images.length > 0
        ? '<img class="post-thumb" src="' + images[0] + '" alt="" loading="lazy">'
        : '';
      const avatarHtml = (post.user_avatar_url || post.avatar)
        ? '<div class="post-avatar">' + (post.user_avatar_url ? '<img src="' + post.user_avatar_url + '">' : post.avatar) + '</div>'
        : '<div class="post-avatar">🐱</div>';
      return '<div class="post-item">' +
        avatarHtml +
        '<div class="post-content">' +
          '<div class="post-header">' +
            '<span class="post-author">' + (post.username || '匿名') + '</span>' +
            '<span class="post-time">' + formatDate(post.created_at) + '</span>' +
            (post.is_pinned ? '<span class="tag tag-purple">置顶</span>' : '') +
          '</div>' +
          '<div class="post-title-text"><a href="/post/' + post.id + '">' + escapeHtml(post.title) + '</a></div>' +
          '<div class="post-desc">' + escapeHtml(stripHtml(post.content)) + '</div>' +
          '<div class="post-footer">' +
            '<span>👁 ' + (post.view_count || 0) + '</span>' +
            '<span>❤️ ' + (post.like_count || 0) + '</span>' +
            '<span>💬 ' + (post.comment_count || 0) + '</span>' +
          '</div>' +
        '</div>' +
        thumbHtml +
      '</div>';
    }

    function renderArticleCard(post) {
      const images = post.images ? post.images.split(',') : [];
      const imgHtml = images.length > 0
        ? '<img class="card-img" src="' + images[0] + '" alt="" loading="lazy">'
        : '<div class="card-img" style="display:flex;align-items:center;justify-content:center;font-size:2.5rem;background:var(--rule);">🐾</div>';
      return '<div class="card">' +
        '<a href="/post/' + post.id + '">' + imgHtml + '</a>' +
        '<div class="card-body">' +
          '<div class="card-title"><a href="/post/' + post.id + '">' + escapeHtml(post.title) + '</a></div>' +
          '<div class="card-excerpt">' + escapeHtml(stripHtml(post.content)) + '</div>' +
          '<div class="card-meta">' +
            '<span class="author"><span class="emoji">' + (post.avatar || '🐱') + '</span> ' + (post.username || '匿名') + '</span>' +
            '<span>' + formatDate(post.created_at) + '</span>' +
            '<span>👁 ' + (post.view_count || 0) + '</span>' +
          '</div>' +
        '</div>' +
      '</div>';
    }

    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
    function stripHtml(str) {
      if (!str) return '';
      return str.replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
    }

    /* ===== Pagination Helper ===== */
    function renderPagination(total, page, limit, callback) {
      const totalPages = Math.ceil(total / limit);
      if (totalPages <= 1) return '';
      let html = '<div class="pagination">';
      html += '<button class="page-btn ' + (page <= 1 ? 'disabled' : '') + '" ' + (page > 1 ? 'onclick="' + callback + '(' + (page - 1) + ')"' : '') + '>&laquo;</button>';
      for (let i = 1; i <= totalPages; i++) {
        if (totalPages > 7 && i > 3 && i < totalPages - 1 && Math.abs(i - page) > 1) {
          if (i === 4 || i === totalPages - 2) html += '<span style="color:var(--muted);">...</span>';
          continue;
        }
        html += '<button class="page-btn ' + (i === page ? 'active' : '') + '" onclick="' + callback + '(' + i + ')">' + i + '</button>';
      }
      html += '<button class="page-btn ' + (page >= totalPages ? 'disabled' : '') + '" ' + (page < totalPages ? 'onclick="' + callback + '(' + (page + 1) + ')"' : '') + '>&raquo;</button>';
      html += '</div>';
      return html;
    }
  </script>

  <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.min.js"></script>
  <!-- Page-specific scripts placeholder -->
  <%- typeof pageScript !== 'undefined' ? pageScript : '' %>
</body>
</html>
