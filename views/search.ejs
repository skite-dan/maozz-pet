<%
  var body = '';
  body += '<div class="breadcrumb">';
  body += '  <a href="/">首页</a> <span class="sep">/</span>';
  body += '  <span class="current">搜索结果</span>';
  body += '</div>';

  body += '<div class="page-layout">';
  body += '  <div class="content-area">';
  body += '    <div class="search-info" id="searchInfo">搜索中...</div>';
  body += '    <div class="post-list" id="searchResults">';
  body += '      <div class="loading"><div class="spinner"></div>加载中...</div>';
  body += '    </div>';
  body += '    <div id="searchPagination"></div>';
  body += '  </div>';

  // Sidebar
  body += '  <aside class="sidebar">';
  body += '    <div class="widget">';
  body += '      <h3 class="widget-title">🔍 搜索筛选</h3>';
  body += '      <div class="form-group">';
  body += '        <label class="form-label">内容类型</label>';
  body += '        <select class="form-input" id="searchType" onchange="doSearch(1)">';
  body += '          <option value="">全部</option>';
  body += '          <option value="forum">论坛帖子</option>';
  body += '          <option value="knowledge">养宠百科</option>';
  body += '          <option value="story">萌宠故事</option>';
  body += '        </select>';
  body += '      </div>';
  body += '      <div class="form-group">';
  body += '        <label class="form-label">排序方式</label>';
  body += '        <select class="form-input" id="searchSort" onchange="doSearch(1)">';
  body += '          <option value="latest">最新发布</option>';
  body += '          <option value="hot">最热门</option>';
  body += '        </select>';
  body += '      </div>';
  body += '    </div>';

  body += '    <div class="widget">';
  body += '      <h3 class="widget-title">🏷️ 热门搜索</h3>';
  body += '      <div class="tag-cloud">';
  body += '        <a href="/search?keyword=猫咪" class="tag">猫咪</a>';
  body += '        <a href="/search?keyword=狗狗" class="tag">狗狗</a>';
  body += '        <a href="/search?keyword=猫粮推荐" class="tag">猫粮推荐</a>';
  body += '        <a href="/search?keyword=宠物健康" class="tag">宠物健康</a>';
  body += '        <a href="/search?keyword=新手养猫" class="tag">新手养猫</a>';
  body += '        <a href="/search?keyword=狗狗训练" class="tag">狗狗训练</a>';
  body += '      </div>';
  body += '    </div>';
  body += '  </aside>';
  body += '</div>';
%>

<%
  var pageScript = '';
  pageScript += '<script>';
  pageScript += '(function() {';
  pageScript += '  const params = new URLSearchParams(window.location.search);';
  pageScript += '  const keyword = params.get("keyword") || "";';
  pageScript += '  const urlType = params.get("type") || "";';
  pageScript += '  let searchPage = 1;';
  pageScript += '  const searchLimit = 10;';

  pageScript += '  // Set initial values';
  pageScript += '  if (urlType) document.getElementById("searchType").value = urlType;';

  pageScript += '  function doSearch(page) {';
  pageScript += '    searchPage = page;';
  pageScript += '    const type = document.getElementById("searchType").value;';
  pageScript += '    const sort = document.getElementById("searchSort").value;';
  pageScript += '    let url = "/api/posts?keyword=" + encodeURIComponent(keyword) + "&page=" + page + "&limit=" + searchLimit + "&sort=" + sort;';
  pageScript += '    if (type) url += "&type=" + type;';
  pageScript += '    fetch(url)';
  pageScript += '      .then(res => res.json())';
  pageScript += '      .then(data => {';
  pageScript += '        if (data.code === 200) {';
  pageScript += '          document.getElementById("searchInfo").innerHTML = \'搜索 "<strong>\' + escapeHtml(keyword) + \'</strong>" 共找到 <strong>\' + data.data.total + \'</strong> 条结果\';';
  pageScript += '          const area = document.getElementById("searchResults");';
  pageScript += '          if (data.data.posts.length > 0) {';
  pageScript += '            area.innerHTML = data.data.posts.map(p => renderPostItem(p)).join("");';
  pageScript += '            document.getElementById("searchPagination").innerHTML = renderPagination(data.data.total, page, searchLimit, "doSearch");';
  pageScript += '          } else {';
  pageScript += '            area.innerHTML = \'<div class="empty-state"><div class="empty-icon">🔍</div><p>未找到相关内容，换个关键词试试？</p></div>\';';
  pageScript += '          }';
  pageScript += '        }';
  pageScript += '      })';
  pageScript += '      .catch(e => console.error(e));';
  pageScript += '  }';

  pageScript += '  window.doSearch = doSearch;';

  pageScript += '  if (keyword) {';
  pageScript += '    doSearch(1);';
  pageScript += '  } else {';
  pageScript += '    document.getElementById("searchInfo").innerHTML = "请输入搜索关键词";';
  pageScript += '    document.getElementById("searchResults").innerHTML = \'<div class="empty-state"><div class="empty-icon">🔍</div><p>请输入关键词开始搜索</p></div>\';';
  pageScript += '  }';
  pageScript += '})();';
  pageScript += '</script>';
%>

<%- include('layout', { title: title, bodyClass: 'page-search', body: body, pageScript: pageScript }) %>
